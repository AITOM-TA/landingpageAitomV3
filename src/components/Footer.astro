---
interface Props {
  lang?: 'fr' | 'en';
}
const { lang = 'fr' } = Astro.props;
const isEn = lang === 'en';
const localeRoot = isEn ? '/en/' : '/';
const p = Astro.url.pathname.replace(/\/$/, '') || '/';
const onHome = p === (isEn ? '/en' : '/');
const anchor = (id: string) => (onHome ? `#${id}` : `${localeRoot}#${id}`);

const t = {
  fr: {
    rights: "© 2026 Aitom. Tous droits réservés. Antibes · Côte d'Azur.",
    nav: [
      { label: 'La solution', href: anchor('solution') },
      { label: 'Comment ça marche', href: anchor('fonctionnement') },
      { label: 'Résultats', href: anchor('projets') },
      { label: 'Blog', href: '/blog' },
      { label: 'FAQ', href: anchor('faq') },
    ],
    legal: [
      { label: 'Mentions légales', href: '/mentions-legales' },
      { label: 'Politique de confidentialité', href: '/politique-de-confidentialite' },
    ],
    navAria: 'Liens de navigation en bas de page',
  },
  en: {
    rights: '© 2026 Aitom. All rights reserved. Antibes, French Riviera.',
    nav: [
      { label: 'The solution', href: anchor('solution') },
      { label: 'How it works', href: anchor('fonctionnement') },
      { label: 'Results', href: anchor('projets') },
      { label: 'Blog', href: '/en/blog' },
      { label: 'FAQ', href: anchor('faq') },
    ],
    legal: [
      { label: 'Legal notice', href: '/en/legal-notice' },
      { label: 'Privacy policy', href: '/en/privacy-policy' },
    ],
    navAria: 'Footer navigation links',
  },
}[lang];
---

<footer class="border-t border-border">
  <div class="max-w-container mx-auto px-8 py-12">

    <!-- Top row : gauche (logo + contact) / droite (liens), alignés en bas -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-12">

      <!-- Gauche : logo puis contact -->
      <div class="flex flex-col gap-6">
        <a href={localeRoot} class="flex items-center gap-2.5 hover:opacity-80 transition-opacity duration-200" aria-label="Aitom">
          <img src="/logo-icon.png" alt="" class="h-6 w-6" />
          <span class="font-display font-bold text-ink text-lg tracking-[-0.02em] leading-none">Aitom</span>
        </a>
        <div class="flex flex-wrap items-center gap-x-8 gap-y-3">
          <a href="mailto:contact@aitom.fr" class="text-sm text-muted hover:text-accent transition-colors duration-200">
            contact@aitom.fr
          </a>
          <a href="tel:+33777313245" class="text-sm text-muted hover:text-accent transition-colors duration-200">
            +33 7 77 31 32 45
          </a>
          <a
            href="https://www.linkedin.com/company/aitom"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-muted hover:text-accent transition-colors duration-200"
          >
            LinkedIn
          </a>
        </div>
      </div>

      <!-- Droite : liens, alignés en bas (même niveau que la ligne contact) -->
      <nav aria-label={t.navAria}>
        <ul class="flex flex-wrap gap-x-8 gap-y-2 list-none md:justify-end">
          {t.nav.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted hover:text-ink transition-colors duration-200">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-4 pt-6 border-t border-border">
      <span class="text-xs text-faint">{t.rights}</span>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
        {t.legal.map((link) => (
          <a href={link.href} class="text-xs text-faint hover:text-muted transition-colors duration-200">{link.label}</a>
        ))}
      </div>
    </div>

  </div>
</footer>
