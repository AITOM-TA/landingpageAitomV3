---
interface Props {
  lang?: 'fr' | 'en';
}
const { lang = 'fr' } = Astro.props;

const t = {
  fr: {
    eyebrow: 'Le coût caché',
    heading: ['Ce que vous coûtent', 'les appels manqués'],
    note: ['La plupart des gérants ne voient jamais cet argent partir.', 'Pourtant, il part chaque jour.'],
    closing: "Un seul client gagné par semaine grâce à un appel décroché rembourse souvent l'outil pour le mois entier.",
    stats: [
      { figure: '15 %', label: 'des appels restent sans réponse', description: "Réunion, chantier, déjà au téléphone : chaque appel manqué part directement chez le concurrent qui, lui, décroche." },
      { figure: '3 000 €', label: 'par mois pour une secrétaire', description: "Et il faut encore gérer les congés, les arrêts maladie, la formation et les heures où personne ne répond." },
      { figure: '23 min', label: 'perdues à chaque interruption', description: "C'est le temps qu'il faut pour se reconcentrer après un appel. Multipliez par le nombre d'appels d'une journée." },
    ],
  },
  en: {
    eyebrow: 'The hidden cost',
    heading: ['What missed calls', 'are costing you'],
    note: ['Most owners never see this money leave.', 'Yet it walks out the door every day.'],
    closing: 'A single customer won each week from a call you answered often pays for the whole month.',
    stats: [
      { figure: '15%', label: 'of calls go unanswered', description: 'In a meeting, on a job site, already on the phone: every missed call goes straight to the competitor who does pick up.' },
      { figure: '$3,000', label: 'a month for a receptionist', description: 'And you still have to cover vacation, sick days, training, and the hours when nobody answers.' },
      { figure: '23 min', label: 'lost with every interruption', description: "That's how long it takes to refocus after a call. Multiply that by the number of calls in a day." },
    ],
  },
}[lang];
---

<section id="cout" class="py-section-sm md:py-section border-t border-border">
  <div class="max-w-container mx-auto px-8">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6">
      <div data-animate>
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">{t.eyebrow}</p>
        <h2 class="font-display font-bold text-display text-ink">
          {t.heading[0]}<br>{t.heading[1]}
        </h2>
      </div>
      <p class="text-sm text-muted max-w-[300px] md:text-right leading-relaxed" data-animate data-delay="1">
        {t.note[0]}<br>{t.note[1]}
      </p>
    </div>

    <!-- Stat cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border">
      {t.stats.map((stat, i) => (
        <div
          class="stat-card bg-bg p-10 md:p-12"
          data-animate
          data-delay={String((i % 3) + 1)}
        >
          <div class="flex flex-col h-full min-h-[240px]">
            <span class="font-display font-bold text-[3.5rem] md:text-[4rem] leading-none text-accent tracking-[-0.03em] mb-3 block">
              {stat.figure}
            </span>
            <h3 class="font-display font-bold text-display-sm text-ink mb-4">{stat.label}</h3>
            <p class="text-sm text-muted leading-relaxed mt-auto">
              {stat.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Closing line -->
    <p class="text-[17px] leading-[1.65] text-muted max-w-[560px] mt-16" data-animate>
      {t.closing}
    </p>

  </div>
</section>

<style>
  .stat-card {
    transition: background-color 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .stat-card:hover {
    background-color: #F1EDE4;
  }
</style>
