---
const secondary = [
  {
    src: '/app/historique.webp',
    alt: "Historique des appels dans l'application Aitom : liste complète des appels avec date, durée et numéros.",
    title: 'Historique des appels',
    description: 'Chaque appel reçu, horodaté et accessible à tout moment.',
  },
  {
    src: '/app/transcription.webp',
    alt: "Détail d'une conversation dans Aitom : lecteur audio, transcription, résumé et informations de l'appel.",
    title: 'Transcriptions & résumés',
    description: "L'enregistrement, le résumé écrit et le motif de chaque appel.",
  },
];
---

<section id="plateforme" class="py-section-sm md:py-section border-t border-border">
  <div class="max-w-container mx-auto px-8">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6">
      <div data-animate>
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">La plateforme</p>
        <h2 class="font-display font-bold text-display text-ink">Tout votre accueil,<br>dans une seule app</h2>
      </div>
      <p class="text-sm text-muted max-w-[300px] md:text-right leading-relaxed" data-animate data-delay="1">
        Rien à installer. Vous suivez vos appels depuis votre téléphone ou votre ordinateur.
      </p>
    </div>

    <!-- Featured: dashboard -->
    <figure class="app-frame" data-animate>
      <div class="app-chrome" aria-hidden="true">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      </div>
      <img
        src="/app/dashboard.webp"
        alt="Tableau de bord Aitom : nombre d'appels traités, durée totale, durée moyenne et graphique des appels quotidiens."
        width="1920"
        height="1080"
        loading="lazy"
        decoding="async"
        class="app-img"
      />
    </figure>
    <figcaption class="text-sm text-muted mt-4 max-w-[520px]" data-animate>
      <span class="text-ink font-medium">Tableau de bord.</span> Appels reçus, durée des conversations, activité du jour : l'essentiel en un coup d'œil.
    </figcaption>

    <!-- Secondary screens -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border mt-16">
      {secondary.map((shot, i) => (
        <div class="shot-card bg-bg p-6 md:p-8" data-animate data-delay={String((i % 2) + 1)}>
          <div class="shot-frame">
            <img
              src={shot.src}
              alt={shot.alt}
              width="1920"
              height="1080"
              loading="lazy"
              decoding="async"
              class="app-img"
            />
          </div>
          <h3 class="font-display font-bold text-lg text-ink mt-6 mb-2">{shot.title}</h3>
          <p class="text-sm text-muted leading-relaxed">{shot.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* App window mockup */
  .app-frame {
    border: 1px solid #DCD5C8;
    border-radius: 8px;
    overflow: hidden;
    background-color: #F1EDE4;
    box-shadow: 0 24px 60px -28px rgba(26, 23, 18, 0.22);
  }

  .app-chrome {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 14px 18px;
    border-bottom: 1px solid #DCD5C8;
    background-color: #E7E1D5;
  }

  .app-chrome .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background-color: #B3AA9B;
    display: inline-block;
  }

  .app-img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Secondary screenshot cards */
  .shot-card {
    transition: background-color 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .shot-card:hover {
    background-color: #F1EDE4;
  }

  .shot-frame {
    border: 1px solid #DCD5C8;
    border-radius: 6px;
    overflow: hidden;
    background-color: #FAF8F2;
  }
</style>
