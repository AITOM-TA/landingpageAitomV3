---
const features = [
  {
    title: 'Tableau de bord',
    description: "Appels reçus, rendez-vous pris, temps gagné — l'essentiel en un coup d'œil.",
  },
  {
    title: 'Historique des appels',
    description: 'Chaque appel enregistré, horodaté et accessible à tout moment.',
  },
  {
    title: 'Transcriptions',
    description: "Le résumé écrit de chaque conversation, pour rappeler en connaissant déjà le besoin.",
  },
];
---

<section id="plateforme" class="py-section-sm md:py-section border-t border-border">
  <div class="max-w-container mx-auto px-8">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6">
      <div data-animate>
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">La plateforme</p>
        <h2 class="font-display font-bold text-display text-ink">Tout votre accueil,<br>dans une seule app</h2>
      </div>
      <p class="text-sm text-muted max-w-[300px] md:text-right leading-relaxed" data-animate data-delay="1">
        Rien à installer. Vous suivez vos appels depuis votre téléphone ou votre ordinateur.
      </p>
    </div>

    <!-- Main app preview placeholder -->
    <div class="app-frame" data-animate>
      <div class="app-chrome" aria-hidden="true">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
      </div>
      <div class="app-screen">
        <span class="app-placeholder-label">Aperçu de l'application — bientôt disponible</span>
      </div>
    </div>

    <!-- Feature placeholders -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border mt-px">
      {features.map((feature, i) => (
        <div class="feature-card bg-bg p-8 md:p-10" data-animate data-delay={String((i % 3) + 1)}>
          <!-- Thumbnail placeholder -->
          <div class="thumb-placeholder mb-6" aria-hidden="true"></div>
          <h3 class="font-display font-bold text-lg text-ink mb-2">{feature.title}</h3>
          <p class="text-sm text-muted leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* App window mockup */
  .app-frame {
    border: 1px solid #DCD5C8;
    border-radius: 8px;
    overflow: hidden;
    background-color: #F1EDE4;
  }

  .app-chrome {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 14px 18px;
    border-bottom: 1px solid #DCD5C8;
    background-color: #E7E1D5;
  }

  .app-chrome .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background-color: #B3AA9B;
    display: inline-block;
  }

  .app-screen {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: linear-gradient(135deg, #F1EDE4 0%, #FAF8F2 100%);
  }

  .app-placeholder-label {
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    color: #B3AA9B;
  }

  /* Feature thumbnail placeholders */
  .feature-card {
    transition: background-color 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .feature-card:hover {
    background-color: #F1EDE4;
  }

  .thumb-placeholder {
    aspect-ratio: 4 / 3;
    border-radius: 4px;
    border: 1px solid #DCD5C8;
    background-image:
      linear-gradient(135deg, #F1EDE4 0%, #E7E1D5 100%);
  }
</style>
