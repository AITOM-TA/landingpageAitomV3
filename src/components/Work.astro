---
interface Props {
  lang?: 'fr' | 'en';
}
const { lang = 'fr' } = Astro.props;

const t = {
  fr: {
    eyebrow: 'Projets',
    heading: ['Ce que nous avons', 'construit'],
    note: 'Projets sélectionnés, données anonymisées.',
    cards: [
      { n: '01', tag: 'Éditeur de logiciel B2B', title: 'Standard IA & gestion des urgences', desc: "Notre IA répond aux appels, qualifie chaque demande et transfère les urgences au bon interlocuteur en temps réel. Plus aucun cas critique ne reste sans réponse.", aria: 'Projet : standard IA & gestion des urgences' },
      { n: '02', tag: 'Cabinet de kinésithérapie', title: '100 appels par jour, zéro manqué', desc: "L'IA décroche chaque appel et gère les rendez-vous directement dans l'agenda. Les praticiens restent avec leurs patients.", aria: 'Projet : 100 appels par jour, zéro manqué' },
      { n: '03', tag: 'Cabinet comptable', title: 'Accueil & suivi des dossiers', desc: "L'IA gère les appels clients, répond aux questions courantes et renseigne les dossiers en direct. Des heures gagnées chaque semaine.", aria: 'Projet : accueil & suivi des dossiers' },
    ],
  },
  en: {
    eyebrow: 'Case studies',
    heading: ["What we've", 'built'],
    note: 'Selected projects, anonymized data.',
    cards: [
      { n: '01', tag: 'B2B software company', title: 'AI answering & urgent call handling', desc: 'Our AI answers calls, qualifies every request and routes urgent ones to the right person in real time. No critical case ever goes unanswered.', aria: 'Case study: AI answering and urgent call handling' },
      { n: '02', tag: 'Physical therapy practice', title: '100 calls a day, zero missed', desc: 'The AI picks up every call and manages appointments right in the calendar. Providers stay with their patients.', aria: 'Case study: 100 calls a day, zero missed' },
      { n: '03', tag: 'Accounting firm', title: 'Call answering & case follow-up', desc: 'The AI handles client calls, answers common questions and updates files live. Hours saved every week.', aria: 'Case study: call answering and case follow-up' },
    ],
  },
}[lang];
---

<section id="projets" class="py-section-sm md:py-section border-t border-border">
  <div class="max-w-container mx-auto px-8">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-14 gap-6">
      <div data-animate>
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">{t.eyebrow}</p>
        <h2 class="font-display font-bold text-display text-ink">{t.heading[0]}<br><em>{t.heading[1]}</em></h2>
      </div>
      <p class="text-sm text-muted" data-animate data-delay="1">
        {t.note}
      </p>
    </div>

    <!-- Grid -->
    <div class="work-grid" data-animate data-delay="1">
      {t.cards.map((card, i) => (
        <a href="#contact" class:list={['work-card', 'group', i === 0 && 'work-card--large']} aria-label={card.aria}>
          <div class="work-card-inner">
            <div class="flex items-start justify-between mb-auto">
              <span class="text-xs font-sans text-faint">{card.n}</span>
              <span class="tag">{card.tag}</span>
            </div>
            <div class="mt-auto">
              <h3 class="font-display font-bold text-display-sm text-ink mb-3 group-hover:text-ink transition-colors duration-200">
                {card.title}
              </h3>
              <p class="text-sm text-muted leading-relaxed">
                {card.desc}
              </p>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto;
    gap: 1px;
    background-color: #DCD5C8;
  }

  @media (min-width: 768px) {
    .work-grid {
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: repeat(2, minmax(260px, auto));
    }

    .work-card--large {
      grid-column: 1 / 8;
      grid-row: 1 / 3;
    }

    .work-card:not(.work-card--large):nth-child(2) {
      grid-column: 8 / 13;
      grid-row: 1 / 2;
    }

    .work-card:not(.work-card--large):nth-child(3) {
      grid-column: 8 / 13;
      grid-row: 2 / 3;
    }
  }

  .work-card {
    display: block;
    background-color: #FAF8F2;
    transition:
      background-color 250ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 250ms cubic-bezier(0.16, 1, 0.3, 1);
    text-decoration: none;
    cursor: pointer;
  }

  .work-card:hover {
    background-color: #F1EDE4;
  }

  .work-card-inner {
    padding: 2.5rem;
    height: 100%;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .work-card--large .work-card-inner {
      padding: 3.5rem;
      min-height: unset;
    }
  }

  .tag {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6B635A;
    background-color: #E7E1D5;
    border: 1px solid #DCD5C8;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .work-card:hover .tag {
    border-color: rgba(105, 103, 251, 0.35);
    color: #6967FB;
    background-color: rgba(105, 103, 251, 0.10);
    transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
