---
const projects = [
  {
    number: '01',
    title: 'Automatisation RH',
    tag: 'Cabinet de conseil',
    description:
      "Traitement automatique des CV, scoring candidats et onboarding — réduit de 3 semaines à 48h.",
    large: true,
  },
  {
    number: '02',
    title: 'Pipeline data client',
    tag: 'E-commerce B2B',
    description:
      "Extraction et enrichissement automatique depuis 6 sources de données hétérogènes.",
    large: false,
  },
  {
    number: '03',
    title: 'Agent support interne',
    tag: 'Scale-up SaaS',
    description:
      "70% des requêtes support traitées sans intervention humaine. Délai moyen : 4 secondes.",
    large: false,
  },
];
---

<section id="projets" class="py-section-sm md:py-section border-t border-border">
  <div class="max-w-container mx-auto px-8">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-14 gap-6">
      <div data-animate>
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">Projets</p>
        <h2 class="font-display font-bold text-display text-ink">Ce que nous avons<br><em>construit</em></h2>
      </div>
      <p class="text-sm text-muted" data-animate data-delay="1">
        Projets sélectionnés — données anonymisées.
      </p>
    </div>

    <!-- Grid -->
    <div class="work-grid" data-animate data-delay="1">

      <!-- Large card -->
      <a href="#contact" class="work-card work-card--large group" aria-label="Projet : Automatisation RH">
        <div class="work-card-inner">
          <div class="flex items-start justify-between mb-auto">
            <span class="text-xs font-sans text-faint">01</span>
            <span class="tag">Cabinet de conseil</span>
          </div>
          <div class="mt-auto">
            <h3 class="font-display font-bold text-display-sm text-ink mb-3 group-hover:text-ink transition-colors duration-200">
              Automatisation RH
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Traitement automatique des CV, scoring candidats et onboarding — réduit de 3 semaines à 48h.
            </p>
          </div>
        </div>
      </a>

      <!-- Small card 2 -->
      <a href="#contact" class="work-card group" aria-label="Projet : Pipeline data client">
        <div class="work-card-inner">
          <div class="flex items-start justify-between mb-auto">
            <span class="text-xs font-sans text-faint">02</span>
            <span class="tag">E-commerce B2B</span>
          </div>
          <div class="mt-auto">
            <h3 class="font-display font-bold text-display-sm text-ink mb-3">
              Pipeline data client
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              Extraction et enrichissement automatique depuis 6 sources hétérogènes.
            </p>
          </div>
        </div>
      </a>

      <!-- Small card 3 -->
      <a href="#contact" class="work-card group" aria-label="Projet : Agent support interne">
        <div class="work-card-inner">
          <div class="flex items-start justify-between mb-auto">
            <span class="text-xs font-sans text-faint">03</span>
            <span class="tag">Scale-up SaaS</span>
          </div>
          <div class="mt-auto">
            <h3 class="font-display font-bold text-display-sm text-ink mb-3">
              Agent support interne
            </h3>
            <p class="text-sm text-muted leading-relaxed">
              70% des requêtes traitées sans intervention humaine. Délai moyen : 4 secondes.
            </p>
          </div>
        </div>
      </a>

    </div>

  </div>
</section>

<style>
  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto;
    gap: 1px;
    background-color: #DCD5C8;
  }

  @media (min-width: 768px) {
    .work-grid {
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: repeat(2, minmax(260px, auto));
    }

    .work-card--large {
      grid-column: 1 / 8;
      grid-row: 1 / 3;
    }

    .work-card:not(.work-card--large):nth-child(2) {
      grid-column: 8 / 13;
      grid-row: 1 / 2;
    }

    .work-card:not(.work-card--large):nth-child(3) {
      grid-column: 8 / 13;
      grid-row: 2 / 3;
    }
  }

  .work-card {
    display: block;
    background-color: #FAF8F2;
    transition:
      background-color 250ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 250ms cubic-bezier(0.16, 1, 0.3, 1);
    text-decoration: none;
    cursor: pointer;
  }

  .work-card:hover {
    background-color: #F1EDE4;
  }

  .work-card-inner {
    padding: 2.5rem;
    height: 100%;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .work-card--large .work-card-inner {
      padding: 3.5rem;
      min-height: unset;
    }
  }

  .tag {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6B635A;
    background-color: #E7E1D5;
    border: 1px solid #DCD5C8;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .work-card:hover .tag {
    border-color: rgba(10, 124, 132, 0.35);
    color: #0A7C84;
    background-color: rgba(10, 124, 132, 0.10);
    transition: all 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
