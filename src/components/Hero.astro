---
import PhoneMock from './PhoneMock.astro';

interface Props {
  lang?: 'fr' | 'en';
}
const { lang = 'fr' } = Astro.props;

const t = {
  fr: {
    aria: 'Héro',
    label: 'Standard téléphonique IA',
    ctaPrimary: "Discuter d'un projet",
    ctaSecondary: 'Voir les résultats',
    marquee: [
      'Appels captés 24/7', 'Prise de rendez-vous', 'Zéro appel manqué', 'Qualification des leads',
      'Disponible nuit & week-end', 'Réponse immédiate', 'Transfert intelligent', 'Standard sur mesure',
    ],
  },
  en: {
    aria: 'Hero',
    label: 'AI Answering Service',
    ctaPrimary: "Let's talk",
    ctaSecondary: 'See the results',
    marquee: [
      'Calls answered 24/7', 'Appointment scheduling', 'Zero missed calls', 'Lead qualification',
      'Nights & weekends', 'Instant response', 'Smart transfer', 'Custom answering',
    ],
  },
}[lang];

// Boucle marquee : la liste répétée pour un défilement sans couture.
const marqueeLoop = [...t.marquee, ...t.marquee, ...t.marquee, ...t.marquee];
---

<section class="relative min-h-screen flex flex-col pt-[68px] overflow-hidden" aria-label={t.aria}>

  <!-- Main content -->
  <div class="flex-1 flex items-center relative z-10">
    <div class="max-w-container mx-auto px-8 w-full py-10 lg:py-12">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">

        <!-- Texte -->
        <div class="max-w-[560px]">

          <!-- Label -->
          <p class="text-xs font-sans font-semibold text-accent uppercase tracking-[0.14em] mb-5" data-animate>
            {t.label}
          </p>

          <!-- Headline -->
          <h1 class="font-display font-bold text-hero text-ink mb-5" data-animate data-delay="1">
            {lang === 'en' ? (
              <Fragment>A missed call<br>is a lost <em>customer</em>.</Fragment>
            ) : (
              <Fragment>Un appel manqué,<br>c'est un client <em>perdu</em>.</Fragment>
            )}
          </h1>

          <!-- Subtitle -->
          <p class="text-[17px] leading-[1.65] text-muted max-w-[520px] mb-8" data-animate data-delay="2">
            {lang === 'en'
              ? "Aitom answers 100% of your calls, 24/7, books your appointments and helps your customers, even when you're busy, in a meeting, or already on the phone."
              : 'Aitom répond à 100 % de vos appels, 24h/24, prend vos rendez-vous et renseigne vos clients, même quand vous êtes occupé, en rendez-vous ou déjà au téléphone.'}
          </p>

          <!-- CTAs -->
          <div class="flex flex-wrap items-center gap-x-10 gap-y-5" data-animate data-delay="3">
            <a
              href="#contact"
              class="btn-primary inline-block bg-accent text-bg text-sm font-semibold px-7 py-[14px] rounded"
            >
              {t.ctaPrimary}
            </a>
            <a
              href="#projets"
              class="btn-secondary inline-flex items-center gap-2 text-sm text-muted hover:text-ink transition-colors duration-300 ease-expo group"
            >
              <span class="btn-label">{t.ctaSecondary}</span>
              <span class="inline-block group-hover:translate-x-2 transition-transform duration-300 ease-expo">→</span>
            </a>
          </div>

        </div>

        <!-- Mockup téléphone -->
        <div class="flex justify-center lg:justify-end" data-animate data-delay="2">
          <PhoneMock lang={lang} />
        </div>

      </div>
    </div>
  </div>

  <!-- Marquee strip -->
  <div class="border-t border-b border-border overflow-hidden relative z-10" aria-hidden="true">
    <div class="py-[14px]">
      <div class="marquee-row whitespace-nowrap">
        <span class="marquee-inner inline-flex items-center gap-0">
          {marqueeLoop.map((item) => (
            <Fragment>
              <span class="marquee-item">{item}</span>
              <span class="marquee-dot">·</span>
            </Fragment>
          ))}
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  /* Hero headline */
  .text-hero {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  h1 em {
    font-style: italic;
  }

  /* Animated arc */
  .arc-spin {
    animation: arc-rotate 14s linear infinite;
  }

  @keyframes arc-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Marquee */
  .marquee-inner {
    animation: marquee 28s linear infinite;
    will-change: transform;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-25%); }
  }

  .marquee-item {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #B3AA9B;
    padding: 0 2rem;
    flex-shrink: 0;
  }

  .marquee-dot {
    color: #B3AA9B;
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .arc-spin { animation: none; }
    .marquee-inner { animation: none; }
  }
</style>
