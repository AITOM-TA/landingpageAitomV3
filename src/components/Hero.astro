          <span class="marquee-dot">·</span>
          <span class="marquee-item">Intégrations</span>
          <span class="marquee-dot">·</span>
          <span class="marquee-item">LLM</span>
          <span class="marquee-dot">·</span>
          <span class="marquee-item">Données</span>
          <span class="marquee-dot">·</span>
          <span class="marquee-item">NLP</span>
          <span class="marquee-dot">·</span>
        </span>
