---
---

<section id="contact" class="py-section-sm md:py-section border-t border-border">
  <div class="max-w-container mx-auto px-8">
    <div class="max-w-[900px]">

      <!-- Label -->
      <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-10" data-animate>
        Contact
      </p>

      <!-- Oversized headline -->
      <h2 class="font-display font-bold text-display text-ink mb-16" data-animate data-delay="1">
        Vous avez un projet.<br>
        On a les outils pour<br>le <em>construire</em>.
      </h2>

      <!-- Email link -->
      <div data-animate data-delay="2">
        <a
          href="mailto:contact@aitom.fr"
          class="email-link group inline-flex items-baseline gap-4 font-display font-bold text-display-sm text-ink hover:text-accent transition-colors duration-300"
          aria-label="Envoyer un email à contact@aitom.fr"
        >
          <span class="email-text relative">
            contact@aitom.fr
            <span class="email-underline"></span>
          </span>
          <span class="text-muted group-hover:text-accent group-hover:translate-x-2 transition-all duration-300 ease-expo inline-block">
            →
          </span>
        </a>
      </div>

      <!-- Secondary note -->
      <p class="text-sm text-faint mt-10" data-animate data-delay="3">
        On répond sous 24h. Pas de pitch, pas de proposition non sollicitée.
      </p>

    </div>
  </div>
</section>

<style>
  .email-underline {
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: #CCFF00;
    transition: width 450ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .email-link:hover .email-underline {
    width: 100%;
  }
</style>
