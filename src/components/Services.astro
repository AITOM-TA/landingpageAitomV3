---
const services = [
  {
    number: '01',
    name: 'Disponible 24h/24, 7j/7',
    description:
      "Votre standard ne dort jamais. Il répond en moins d'une sonnerie, le soir, le week-end et les jours fériés — plus aucun appel ne tombe dans le vide.",
  },
  {
    number: '02',
    name: 'Prend les rendez-vous tout seul',
    description:
      "Connecté à votre agenda, il propose les créneaux libres et fixe le rendez-vous pendant l'appel. Fini les allers-retours et les agendas en double.",
  },
  {
    number: '03',
    name: 'Qualifie chaque appel',
    description:
      "Il pose les bonnes questions, note l'essentiel et vous transmet uniquement ce qui compte. Vous rappelez les bons clients, au bon moment.",
  },
  {
    number: '04',
    name: 'Une fraction du coût',
    description:
      "Pour bien moins cher qu'une secrétaire, et sans absence ni congé. Vous ne payez plus pour les heures creuses : il est là en permanence.",
  },
];
---

<section id="solution" class="py-section-sm md:py-section border-t border-border">
  <div class="max-w-container mx-auto px-8">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 pb-8 border-b border-border gap-6">
      <div data-animate>
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">La solution</p>
        <h2 class="font-display font-bold text-display text-ink">Un standard qui ne<br>rate jamais un appel</h2>
      </div>
      <p class="text-sm text-muted max-w-[280px] md:text-right leading-relaxed" data-animate data-delay="1">
        Pendant que vous travaillez,<br>il répond, qualifie et prend vos rendez-vous.
      </p>
    </div>

    <!-- Service rows -->
    <div class="divide-y divide-border">
      {services.map((service, i) => (
        <div class="service-row group py-8 md:py-10" data-animate data-delay={String((i % 4) + 1)}>
          <div class="grid grid-cols-12 gap-4 md:gap-8 items-start">

            <!-- Number -->
            <div class="col-span-2 md:col-span-1">
              <span class="service-number text-xs font-sans text-faint group-hover:text-accent transition-colors duration-300 ease-expo pt-[6px] block">
                {service.number}
              </span>
            </div>

            <!-- Name -->
            <div class="col-span-10 md:col-span-5">
              <h3 class="font-display font-bold text-display-sm text-ink group-hover:text-ink transition-colors duration-200">
                {service.name}
              </h3>
              <!-- Mobile description -->
              <p class="md:hidden text-sm text-muted leading-relaxed mt-3">
                {service.description}
              </p>
            </div>

            <!-- Description (desktop, revealed on hover) -->
            <div class="hidden md:block col-span-6 service-desc">
              <p class="text-sm text-muted leading-relaxed pt-[5px]">
                {service.description}
              </p>
            </div>

          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .service-row {
    transition: background-color 200ms cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 4px;
    margin: 0 -8px;
    padding-left: 8px;
    padding-right: 8px;
  }

  .service-row:hover {
    background-color: #F1EDE4;
  }

  .service-desc {
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 350ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 350ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .service-row:hover .service-desc {
    opacity: 1;
    transform: translateY(0);
  }
</style>
