---
const services = [
  {
    number: '01',
    name: 'Conseil IA',
    description:
      "Diagnostiquer les véritables opportunités dans votre organisation. Pas de présentation PowerPoint — un plan d'action concret et priorisé selon vos contraintes réelles.",
  },
  {
    number: '02',
    name: 'Automatisation',
    description:
      'Connecter vos outils, éliminer les tâches répétitives et créer des flux de données fiables entre vos systèmes. Chaque heure économisée est une heure réinvestie sur ce qui compte.',
  },
  {
    number: '03',
    name: 'Agents IA',
    description:
      "Déployer des systèmes autonomes capables d'agir, de décider et d'exécuter dans votre contexte métier. Pas seulement analyser — faire.",
  },
  {
    number: '04',
    name: 'Intégrations sur mesure',
    description:
      "Construire les briques que votre stack ne possède pas encore. API, connecteurs, pipelines de données — conçus pour s'intégrer sans friction à ce que vous avez déjà.",
  },
];
---

<section id="services" class="py-section-sm md:py-section">
  <div class="max-w-container mx-auto px-8">

    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 pb-8 border-b border-border gap-6">
      <div data-animate>
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">Services</p>
        <h2 class="font-display font-bold text-display text-ink">Ce qu'on fait</h2>
      </div>
      <p class="text-sm text-muted max-w-[280px] md:text-right leading-relaxed" data-animate data-delay="1">
        Quatre disciplines.<br>Une seule finalité : créer de la valeur mesurable.
      </p>
    </div>

    <!-- Service rows -->
    <div class="divide-y divide-border">
      {services.map((service, i) => (
        <div class="service-row group py-8 md:py-10" data-animate data-delay={String((i % 4) + 1)}>
          <div class="grid grid-cols-12 gap-4 md:gap-8 items-start">

            <!-- Number -->
            <div class="col-span-2 md:col-span-1">
              <span class="service-number text-xs font-sans text-faint group-hover:text-accent transition-colors duration-300 ease-expo pt-[6px] block">
                {service.number}
              </span>
            </div>

            <!-- Name -->
            <div class="col-span-10 md:col-span-5">
              <h3 class="font-display font-bold text-display-sm text-ink group-hover:text-ink transition-colors duration-200">
                {service.name}
              </h3>
              <!-- Mobile description -->
              <p class="md:hidden text-sm text-muted leading-relaxed mt-3">
                {service.description}
              </p>
            </div>

            <!-- Description (desktop, revealed on hover) -->
            <div class="hidden md:block col-span-6 service-desc">
              <p class="text-sm text-muted leading-relaxed pt-[5px]">
                {service.description}
              </p>
            </div>

          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .service-row {
    transition: background-color 200ms cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 4px;
    margin: 0 -8px;
    padding-left: 8px;
    padding-right: 8px;
  }

  .service-row:hover {
    background-color: #141210;
  }

  .service-desc {
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 350ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 350ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .service-row:hover .service-desc {
    opacity: 1;
    transform: translateY(0);
  }
</style>
