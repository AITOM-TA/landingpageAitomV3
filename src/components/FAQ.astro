---
const faqs = [
  {
    question: 'Faut-il fournir un numéro de téléphone ?',
    answer:
      "Non. Votre standard IA fonctionne sur votre numéro actuel. Vos clients continuent d'appeler le même. On s'occupe du branchement, vous ne changez rien. Si vous préférez un nouveau numéro, on peut aussi vous en fournir un.",
  },
  {
    question: 'Combien de temps pour la mise en place ?',
    answer:
      "Quelques jours. Après un audit de 30 minutes, on configure tout à votre place et votre standard est opérationnel en moins d'une semaine. Aucune compétence technique requise de votre côté.",
  },
  {
    question: 'Comment je suis les appels ?',
    answer:
      "Depuis une application simple, sur téléphone ou ordinateur : historique des appels, enregistrements, transcriptions écrites et rendez-vous pris, en temps réel. Vous gardez toujours la main.",
  },
  {
    question: 'Qui peut l\'utiliser ?',
    answer:
      "Toute TPE ou PME de services : artisans, plombiers, cabinets dentaires, avocats, dépanneurs, agences… Si vous recevez des appels de clients, votre standard IA est fait pour vous.",
  },
];

// Données structurées — la FAQ affichée sert de source unique.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section id="faq" class="py-section-sm md:py-section border-t border-border">
  <div class="max-w-container mx-auto px-8">

    <!-- Header -->
    <div class="mb-16" data-animate>
      <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">FAQ</p>
      <h2 class="font-display font-bold text-display text-ink max-w-md">
        Les questions<br>qu'on nous pose
      </h2>
    </div>

    <!-- Questions -->
    <div class="max-w-[760px] border-t border-border" data-animate data-delay="1">
      {faqs.map((faq) => (
        <details class="faq-item border-b border-border">
          <summary class="faq-summary">
            <span class="font-display font-semibold text-ink text-lg pr-8">{faq.question}</span>
            <span class="faq-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M9 3.5v11M3.5 9h11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </span>
          </summary>
          <div class="faq-answer">
            <p class="text-[15px] leading-[1.7] text-muted pb-7 pr-8">{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>

  </div>
</section>

<style>
  .faq-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.6rem 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-icon {
    flex-shrink: 0;
    color: #6B635A;
    transition: transform 350ms cubic-bezier(0.16, 1, 0.3, 1), color 250ms ease;
  }

  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
    color: #6967FB;
  }

  .faq-summary:hover .faq-icon {
    color: #6967FB;
  }

  /* Animated open/close */
  .faq-answer {
    display: grid;
    grid-template-rows: 1fr;
  }

  .faq-answer > p {
    overflow: hidden;
  }

  .faq-item:not([open]) .faq-answer {
    display: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .faq-item[open] .faq-answer > p {
      animation: faq-reveal 400ms cubic-bezier(0.16, 1, 0.3, 1);
    }
  }

  @keyframes faq-reveal {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
