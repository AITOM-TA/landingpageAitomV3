---
const steps = [
  {
    number: '01',
    title: 'Comprendre',
    description:
      "Pas de solution avant d'avoir cerné le problème réel. Nous passons du temps dans votre quotidien avant de coder la première ligne.",
  },
  {
    number: '02',
    title: 'Concevoir',
    description:
      "Architecture légère, évolutive, sans dette technique inutile. Nous choisissons les outils pour le bon problème — pas les outils à la mode.",
  },
  {
    number: '03',
    title: 'Déployer',
    description:
      "Mise en production intégrée dans vos outils existants. Nous ne livrons pas un prototype — nous livrons un système qui tourne.",
  },
  {
    number: '04',
    title: 'Mesurer',
    description:
      "Résultats suivis, ajustements continus. Pas de boîte noire : vous voyez ce que le système fait et pourquoi.",
  },
];
---

<section id="approche" class="py-section-sm md:py-section border-t border-border">
  <div class="max-w-container mx-auto px-8">

    <!-- Header -->
    <div class="mb-16" data-animate>
      <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">Approche</p>
      <h2 class="font-display font-bold text-display text-ink max-w-sm">
        Comment nous<br><em>travaillons</em>
      </h2>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border">
      {steps.map((step, i) => (
        <div
          class="step-card bg-bg p-10 md:p-12"
          data-animate
          data-delay={String((i % 2) + 1)}
        >
          <div class="flex flex-col h-full min-h-[220px]">
            <span class="font-display font-bold text-[4rem] leading-none text-faint mb-6 block step-number">
              {step.number}
            </span>
            <h3 class="font-display font-bold text-display-sm text-ink mb-4">{step.title}</h3>
            <p class="text-sm text-muted leading-relaxed mt-auto">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .step-card {
    transition: background-color 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .step-card:hover {
    background-color: #141210;
  }

  .step-card:hover .step-number {
    color: #3E3B34;
    transition: color 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
