---
const steps = [
  {
    number: '01',
    title: 'Audit en 30 minutes',
    description:
      "On analyse vos appels, votre activité et vos besoins. Vous repartez avec un plan clair et un devis transparent, sans engagement.",
  },
  {
    number: '02',
    title: 'Installation clé en main',
    description:
      "On configure votre standard et on le branche sur votre numéro existant. Vous n'avez rien à faire : tout est prêt en quelques jours.",
  },
  {
    number: '03',
    title: "Suivi dans l'app",
    description:
      "Vous suivez chaque appel, écoutez les enregistrements et ajustez les réponses en un clic. On reste à vos côtés pour affiner.",
  },
];
---

<section id="fonctionnement" class="py-section-sm md:py-section border-t border-border">
  <div class="max-w-container mx-auto px-8">

    <!-- Header -->
    <div class="mb-16" data-animate>
      <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">Comment ça marche</p>
      <h2 class="font-display font-bold text-display text-ink max-w-md">
        Vous n'avez <em>rien</em><br>à faire
      </h2>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border">
      {steps.map((step, i) => (
        <div
          class="step-card bg-bg p-10 md:p-12"
          data-animate
          data-delay={String((i % 3) + 1)}
        >
          <div class="flex flex-col h-full min-h-[220px]">
            <span class="font-display font-bold text-[4rem] leading-none text-faint mb-6 block step-number">
              {step.number}
            </span>
            <h3 class="font-display font-bold text-display-sm text-ink mb-4">{step.title}</h3>
            <p class="text-sm text-muted leading-relaxed mt-auto">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .step-card {
    transition: background-color 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .step-card:hover {
    background-color: #F1EDE4;
  }

  .step-card:hover .step-number {
    color: #B3AA9B;
    transition: color 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }
</style>
