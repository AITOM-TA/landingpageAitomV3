---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  related: CollectionEntry<'blog'>[];
  lang?: 'fr' | 'en';
}
const { post, related, lang = 'fr' } = Astro.props;
const { Content, headings } = await render(post);

const siteUrl = 'https://aitom.fr';

const t = {
  fr: {
    crumbArticle: 'Article',
    tocHead: 'Dans cet article',
    minRead: 'min de lecture',
    authorRole: "Fondateur d'Aitom",
    authorAlt: "Tanguy, fondateur d'Aitom",
    authorBio: "On met en place des standards téléphoniques IA pour les artisans, cabinets et PME de services. Pas de hotline anonyme : une équipe qui configure et suit tout de A à Z.",
    ctaTitle: "Un appel manqué, c'est un client perdu.",
    ctaSub: "Voyez ce qu'un standard IA donnerait sur vos propres appels. Audit gratuit, 30 minutes, sans engagement.",
    ctaBtn: 'Parler à un expert',
    contactHref: '/#contact',
    relatedHead: 'Continuer la lecture',
    dateLocale: 'fr-FR',
    blogBase: '/blog',
  },
  en: {
    crumbArticle: 'Article',
    tocHead: 'In this article',
    minRead: 'min read',
    authorRole: 'Founder of Aitom',
    authorAlt: 'Tanguy, founder of Aitom',
    authorBio: 'We set up AI answering services for tradespeople, practices and service SMBs. No anonymous hotline: a team that configures and supports everything from A to Z.',
    ctaTitle: 'A missed call is a lost customer.',
    ctaSub: 'See what an AI answering service would do for your own calls. Free audit, 30 minutes, no commitment.',
    ctaBtn: 'Talk to an expert',
    contactHref: '/en/#contact',
    relatedHead: 'Continue reading',
    dateLocale: 'en-US',
    blogBase: '/en/blog',
  },
}[lang];

const toc = headings.filter((h) => h.depth === 2);
const minutes = Math.max(1, Math.round((post.body ?? '').trim().split(/\s+/).length / 200));
const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat(t.dateLocale, { day: 'numeric', month: 'long', year: 'numeric' }).format(d);

const canonical = `${siteUrl}${t.blogBase}/${post.id}/`;
const heroAbs = new URL(post.data.heroImage, siteUrl).href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  inLanguage: lang,
  headline: post.data.title,
  description: post.data.description,
  image: heroAbs,
  datePublished: post.data.publishDate.toISOString(),
  author: { '@type': 'Person', name: post.data.author },
  publisher: {
    '@type': 'Organization',
    name: 'Aitom',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/logo-icon.png` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};
---

<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
<main>
  <!-- En-tête : titre à gauche, visuel à droite -->
  <header class="max-w-container mx-auto px-8 pt-[calc(68px+3rem)] pb-12">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div>
        <nav class="crumb" aria-label="Breadcrumb">
          <a href={t.blogBase}>Blog</a><span aria-hidden="true">/</span><span>{t.crumbArticle}</span>
        </nav>
        <h1 class="font-display font-bold text-ink mt-5 mb-6 art-title">{post.data.title}</h1>
        <p class="text-[18px] leading-[1.6] text-muted max-w-[520px] mb-7">{post.data.description}</p>
        <div class="art-meta">
          <span class="mi">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.7" />
              <path d="M3 9h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
            </svg>
            {fmtDate(post.data.publishDate)}
          </span>
          <span class="mi">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.7" />
              <path d="M12 7v5l3.5 2" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
            </svg>
            {minutes} {t.minRead}
          </span>
        </div>
      </div>
      <div class="art-hero-img" data-animate>
        <img src={post.data.heroImage} alt={post.data.heroAlt} width="1600" height="900" fetchpriority="high" decoding="async" />
      </div>
    </div>
  </header>

  <!-- Corps : sommaire à gauche, contenu à droite -->
  <div class="max-w-container mx-auto px-8 pb-section-sm md:pb-section">
    <div class="art-grid">
      {toc.length > 0 && (
        <aside class="art-toc-col">
          <nav class="art-toc" aria-label={t.tocHead}>
            <p class="toc-head">{t.tocHead}</p>
            <ol>
              {toc.map((h, i) => (
                <li>
                  <a href={`#${h.slug}`} data-toc={h.slug}>
                    <span class="toc-txt">{h.text}</span>
                    <span class="toc-num">{i + 1}</span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )}

      <div class="art-main">
        <article class="article-body">
          <Content />
        </article>

        <!-- Encart auteur -->
        <div class="author-box">
          <img src="/founder.webp" alt={t.authorAlt} width="120" height="120" loading="lazy" />
          <div>
            <p class="ab-name">{post.data.author}</p>
            <p class="ab-role">{t.authorRole}</p>
            <p class="ab-bio">{t.authorBio}</p>
          </div>
        </div>

        <!-- CTA -->
        <div class="art-cta">
          <p class="cta-title">{t.ctaTitle}</p>
          <p class="cta-sub">{t.ctaSub}</p>
          <a href={t.contactHref} class="btn-primary inline-block bg-accent text-bg text-sm font-semibold px-7 py-[14px] rounded">{t.ctaBtn}</a>
        </div>
      </div>
    </div>

    {related.length > 0 && (
      <section class="related">
        <h2 class="related-head">{t.relatedHead}</h2>
        <div class="grid gap-8 md:grid-cols-2">
          {related.map((p) => (
            <a href={`${t.blogBase}/${p.id}`} class="rel-card group">
              <div class="rel-thumb">
                <img src={p.data.heroImage} alt={p.data.heroAlt} width="1600" height="900" loading="lazy" decoding="async" />
              </div>
              <div class="rel-body">
                <p class="rel-date">{fmtDate(p.data.publishDate)}</p>
                <h3 class="rel-title">{p.data.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</main>

<style>
  .crumb { display: flex; align-items: center; gap: 10px; font-size: 13px; color: #6B635A; }
  .crumb a { color: #6B635A; transition: color .2s; }
  .crumb a:hover { color: #4744D8; }
  .crumb span[aria-hidden] { color: #B3AA9B; }

  .art-title { font-size: clamp(2rem, 4.2vw, 3.2rem); line-height: 1.1; letter-spacing: -0.03em; text-wrap: balance; }

  .art-meta { display: flex; flex-wrap: wrap; gap: 10px 24px; font-size: 14px; color: #6B635A; }
  .art-meta .mi { display: inline-flex; align-items: center; gap: 8px; }
  .art-meta svg { color: #B3AA9B; }

  .art-hero-img { border-radius: 16px; overflow: hidden; border: 1px solid #DCD5C8; box-shadow: 0 20px 50px rgba(26, 23, 18, 0.08); aspect-ratio: 16 / 10; }
  .art-hero-img img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .art-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 1024px) { .art-grid { grid-template-columns: 260px 1fr; gap: 4.5rem; } }

  .art-toc-col { position: relative; }
  .art-toc { position: sticky; top: 100px; border: 1px solid #DCD5C8; border-radius: 14px; padding: 22px 20px; background: #F1EDE4; }
  .toc-head { font-weight: 700; font-size: 15px; color: #1A1712; padding-left: 12px; border-left: 3px solid #6967FB; margin-bottom: 16px; }
  .art-toc ol { list-style: none; display: flex; flex-direction: column; gap: 2px; }
  .art-toc a { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 10px 12px; border-radius: 9px; font-size: 14px; line-height: 1.35; color: #6B635A; transition: background-color .2s, color .2s; }
  .art-toc a:hover { color: #1A1712; background: #E7E1D5; }
  .toc-num { font-size: 12px; font-weight: 700; color: #B3AA9B; flex: none; font-variant-numeric: tabular-nums; }
  .art-toc a.active { color: #4744D8; background: #FAF8F2; box-shadow: inset 0 0 0 1px #C3C2FD; }
  .art-toc a.active .toc-num { color: #6967FB; }
  @media (max-width: 1023px) { .art-toc { position: static; } }

  .article-body { max-width: 720px; }
  .article-body :global(h2) { font-family: 'Figtree', system-ui, sans-serif; font-weight: 700; font-size: clamp(1.5rem, 2.4vw, 2rem); line-height: 1.2; letter-spacing: -0.02em; color: #1A1712; margin: 2.75rem 0 1rem; text-wrap: balance; }
  .article-body :global(h2:first-child) { margin-top: 0; }
  .article-body :global(h3) { font-weight: 700; font-size: 1.2rem; color: #1A1712; margin: 2rem 0 0.75rem; }
  .article-body :global(p) { font-size: 17px; line-height: 1.7; color: #3a352e; margin-bottom: 1.25rem; }
  .article-body :global(ul), .article-body :global(ol) { margin: 0 0 1.5rem 1.25rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .article-body :global(li) { font-size: 17px; line-height: 1.6; color: #3a352e; padding-left: 0.3rem; }
  .article-body :global(li)::marker { color: #6967FB; }
  .article-body :global(strong) { color: #1A1712; font-weight: 700; }
  .article-body :global(a) { color: #4744D8; text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 1px; }
  .article-body :global(a:hover) { text-decoration-thickness: 2px; }
  .article-body :global(blockquote) { margin: 1.5rem 0; padding: 4px 0 4px 22px; border-left: 3px solid #C3C2FD; color: #1A1712; font-size: 17px; line-height: 1.6; }
  .article-body :global(blockquote p) { color: #1A1712; margin-bottom: 0.5rem; }
  .article-body :global(hr) { border: none; border-top: 1px solid #DCD5C8; margin: 2.5rem 0; }
  .article-body :global(table) { display: block; overflow-x: auto; width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 15px; }
  .article-body :global(th) { text-align: left; font-weight: 700; color: #1A1712; background: #F1EDE4; padding: 11px 14px; border: 1px solid #DCD5C8; white-space: nowrap; }
  .article-body :global(td) { padding: 11px 14px; border: 1px solid #DCD5C8; color: #3a352e; vertical-align: top; }

  .author-box { display: flex; gap: 18px; align-items: flex-start; margin-top: 3rem; padding: 24px; border: 1px solid #DCD5C8; border-radius: 14px; background: #F1EDE4; max-width: 720px; }
  .author-box img { width: 64px; height: 64px; border-radius: 50%; object-fit: cover; flex: none; }
  .ab-name { font-weight: 700; color: #1A1712; }
  .ab-role { font-size: 13px; color: #6967FB; margin-bottom: 8px; }
  .ab-bio { font-size: 14.5px; line-height: 1.55; color: #6B635A; }

  .art-cta { margin-top: 2.5rem; padding: 32px; border-radius: 16px; background: linear-gradient(135deg, #1A1712 0%, #2a2540 100%); max-width: 720px; }
  .cta-title { font-family: 'Figtree', system-ui, sans-serif; font-weight: 700; font-size: 1.4rem; letter-spacing: -0.02em; color: #FAF8F2; margin-bottom: 8px; }
  .cta-sub { font-size: 15px; line-height: 1.55; color: #B3AA9B; margin-bottom: 20px; max-width: 460px; }

  .related { margin-top: 5rem; padding-top: 3rem; border-top: 1px solid #DCD5C8; }
  .related-head { font-family: 'Figtree', system-ui, sans-serif; font-weight: 700; font-size: 1.5rem; letter-spacing: -0.02em; color: #1A1712; margin-bottom: 1.75rem; }
  .rel-card { display: flex; gap: 18px; align-items: center; border: 1px solid #DCD5C8; border-radius: 12px; overflow: hidden; background: #FAF8F2; transition: transform .35s cubic-bezier(0.16,1,0.3,1), box-shadow .35s, border-color .35s; }
  .rel-card:hover { transform: translateY(-3px); box-shadow: 0 14px 30px rgba(26,23,18,0.09); border-color: #C3C2FD; }
  .rel-thumb { width: 128px; flex: none; aspect-ratio: 1; overflow: hidden; background: #E7E1D5; }
  .rel-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .rel-body { padding: 14px 16px 14px 0; }
  .rel-date { font-size: 12.5px; color: #B3AA9B; margin-bottom: 5px; }
  .rel-title { font-weight: 700; font-size: 15.5px; line-height: 1.3; color: #1A1712; transition: color .2s; }
  .rel-card:hover .rel-title { color: #4744D8; }
</style>

<script>
  const links = new Map<string, HTMLElement>();
  document.querySelectorAll<HTMLElement>('.art-toc a[data-toc]').forEach((a) => {
    links.set(a.dataset.toc!, a);
  });

  const headings = Array.from(document.querySelectorAll<HTMLElement>('.article-body h2[id]'));
  if (headings.length && links.size) {
    let current = '';
    const setActive = (id: string) => {
      if (id === current) return;
      current = id;
      links.forEach((el) => el.classList.remove('active'));
      links.get(id)?.classList.add('active');
    };
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      },
      { rootMargin: '-90px 0px -70% 0px', threshold: 0 }
    );
    headings.forEach((h) => observer.observe(h));
  }
</script>
