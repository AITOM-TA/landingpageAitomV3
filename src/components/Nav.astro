---
interface Props {
  lang?: 'fr' | 'en';
  /** URL de la page dans l'autre langue (pour le sélecteur FR/EN). */
  altUrl?: string;
}
const { lang = 'fr', altUrl } = Astro.props;
const isEn = lang === 'en';
const localeRoot = isEn ? '/en/' : '/';
// Ancres : pures sur l'accueil de la langue (Lenis smooth scroll), préfixées ailleurs.
const p = Astro.url.pathname.replace(/\/$/, '') || '/';
const onHome = p === (isEn ? '/en' : '/');
const anchor = (id: string) => (onHome ? `#${id}` : `${localeRoot}#${id}`);
const switchUrl = altUrl ?? (isEn ? '/' : '/en/');
const t = {
  fr: { signin: 'Se connecter', cta: 'Parler à un expert', sw: 'EN', swAria: 'View the site in English', open: 'Ouvrir le menu', close: 'Fermer le menu' },
  en: { signin: 'Sign in', cta: 'Talk to an expert', sw: 'FR', swAria: 'Voir le site en français', open: 'Open menu', close: 'Close menu' },
}[lang];
---

<nav id="nav" aria-label="Navigation principale">
  <div class="max-w-container mx-auto px-8 flex items-center justify-between h-[68px]">
    <!-- Wordmark -->
    <a href={localeRoot} class="flex items-center gap-2.5 hover:opacity-80 transition-opacity duration-200" aria-label="Aitom, accueil">
      <img src="/logo-icon.png" alt="" class="h-7 w-7" />
      <span class="font-display font-bold text-ink text-xl tracking-[-0.02em] leading-none">Aitom</span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      <a href={switchUrl} class="lang-switch text-xs font-semibold text-muted hover:text-ink transition-colors duration-200" aria-label={t.swAria}>{t.sw}</a>
      <a href="https://app.aitom.fr" class="text-sm text-muted hover:text-ink transition-colors duration-200 ease-expo">{t.signin}</a>
      <a
        href={anchor('contact')}
        class="btn-primary text-sm font-semibold bg-accent text-bg px-5 py-2.5 rounded"
      >
        {t.cta}
      </a>
    </div>

    <!-- Mobile toggle -->
    <button id="nav-toggle" class="md:hidden text-muted hover:text-ink transition-colors p-1" aria-label={t.open} data-open={t.open} data-close={t.close} aria-expanded="false">
      <svg class="burger-icon" width="22" height="22" viewBox="0 0 22 22" fill="none">
        <path class="b-top" d="M3 6h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <path class="b-mid" d="M3 11h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <path class="b-bot" d="M3 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="nav-mobile" class="menu-wrapper" role="menu">
    <div class="menu-inner">
      <div class="border-t border-border bg-surface px-8 py-6">
        <div class="flex flex-col gap-5">
          <a href="https://app.aitom.fr" class="menu-link text-sm text-muted hover:text-ink transition-colors duration-200" role="menuitem">{t.signin}</a>
          <a href={anchor('contact')} class="menu-link text-sm font-semibold text-accent" role="menuitem">{t.cta} →</a>
          <a href={switchUrl} class="menu-link text-sm text-muted hover:text-ink transition-colors duration-200" role="menuitem" aria-label={t.swAria}>{t.sw}</a>
        </div>
      </div>
    </div>
  </div>
</nav>

<style>
  #nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    border-bottom: 1px solid transparent;
    transition:
      background-color 400ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 400ms cubic-bezier(0.16, 1, 0.3, 1),
      backdrop-filter 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  #nav.nav-scrolled {
    background-color: rgba(250, 248, 242, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom-color: #DCD5C8;
  }

  /* ── Burger icon morphing ── */
  .burger-icon .b-top,
  .burger-icon .b-mid,
  .burger-icon .b-bot {
    transition:
      transform 380ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity   250ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Chaque barre pivote autour de son propre centre exact */
  .burger-icon .b-top { transform-origin: 11px 6px; }
  .burger-icon .b-mid { transform-origin: 11px 11px; }
  .burger-icon .b-bot { transform-origin: 11px 16px; }

  .burger-icon.is-open .b-top {
    transform: translateY(5px) rotate(45deg);
  }

  .burger-icon.is-open .b-mid {
    opacity: 0;
    transform: scaleX(0);
  }

  .burger-icon.is-open .b-bot {
    transform: translateY(-5px) rotate(-45deg);
  }

  /* ── Mobile menu slide-down ── */
  .menu-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 420ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity            300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .menu-wrapper.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .menu-inner {
    overflow: hidden;
  }

  /* Desktop: always hidden */
  @media (min-width: 768px) {
    .menu-wrapper {
      display: none;
    }
  }

  /* ── Stagger links on open ── */
  .menu-link {
    opacity: 0;
    transform: translateY(-6px);
    transition:
      opacity   220ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 220ms cubic-bezier(0.16, 1, 0.3, 1),
      color     200ms ease;
  }

  .menu-wrapper.is-open .menu-link:nth-child(1) { opacity: 1; transform: none; transition-delay: 100ms; }
  .menu-wrapper.is-open .menu-link:nth-child(2) { opacity: 1; transform: none; transition-delay: 150ms; }
  .menu-wrapper.is-open .menu-link:nth-child(3) { opacity: 1; transform: none; transition-delay: 200ms; }

  .lang-switch {
    border: 1px solid #DCD5C8;
    border-radius: 999px;
    padding: 4px 10px;
    letter-spacing: 0.06em;
  }
  .lang-switch:hover { border-color: #B3AA9B; }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  const burger = toggle?.querySelector('.burger-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('is-open');
    menu?.classList.toggle('is-open', !isOpen);
    burger?.classList.toggle('is-open', !isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', (!isOpen ? toggle.dataset.close : toggle.dataset.open) || '');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      burger?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      if (toggle) toggle.setAttribute('aria-label', toggle.dataset.open || '');
    });
  });

  // Nav scroll state
  const nav = document.getElementById('nav');
  if (nav) {
    const update = () => {
      nav.classList.toggle('nav-scrolled', window.scrollY > 60);
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
