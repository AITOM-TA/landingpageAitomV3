---
---

<nav id="nav" aria-label="Navigation principale">
  <div class="max-w-container mx-auto px-8 flex items-center justify-between h-[68px]">
    <!-- Wordmark -->
    <a href="/" class="font-display font-bold text-[1.25rem] text-ink tracking-[-0.03em] hover:text-accent transition-colors duration-200">
      Aitom
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-10">
      <a href="#services" class="text-sm text-muted hover:text-ink transition-colors duration-200 ease-expo">Services</a>
      <a href="#approche" class="text-sm text-muted hover:text-ink transition-colors duration-200 ease-expo">Approche</a>
      <a href="#projets" class="text-sm text-muted hover:text-ink transition-colors duration-200 ease-expo">Projets</a>
      <a
        href="#contact"
        class="text-sm font-semibold bg-accent text-bg px-5 py-2.5 rounded hover:opacity-90 transition-opacity duration-200"
      >
        Discuter d'un projet
      </a>
    </div>

    <!-- Mobile toggle -->
    <button id="nav-toggle" class="md:hidden text-muted hover:text-ink transition-colors p-1" aria-label="Ouvrir le menu" aria-expanded="false">
      <svg id="icon-open" width="22" height="22" viewBox="0 0 22 22" fill="none">
        <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <svg id="icon-close" width="22" height="22" viewBox="0 0 22 22" fill="none" class="hidden">
        <path d="M5 5l12 12M17 5L5 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="nav-mobile"
    class="hidden md:hidden border-t border-border bg-surface px-8 py-6"
    role="menu"
  >
    <div class="flex flex-col gap-5">
      <a href="#services" class="text-sm text-muted hover:text-ink transition-colors duration-200" role="menuitem">Services</a>
      <a href="#approche" class="text-sm text-muted hover:text-ink transition-colors duration-200" role="menuitem">Approche</a>
      <a href="#projets" class="text-sm text-muted hover:text-ink transition-colors duration-200" role="menuitem">Projets</a>
      <a href="#contact" class="text-sm font-semibold text-accent" role="menuitem">Discuter d'un projet →</a>
    </div>
  </div>
</nav>

<style>
  #nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    border-bottom: 1px solid transparent;
    transition:
      background-color 400ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 400ms cubic-bezier(0.16, 1, 0.3, 1),
      backdrop-filter 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  #nav.nav-scrolled {
    background-color: rgba(12, 11, 8, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom-color: #272420;
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
