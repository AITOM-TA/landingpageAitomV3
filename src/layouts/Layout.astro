---
// Bannière cookies masquée pour l'instant, réactiver en remettant
// l'import et <CookieBanner /> dans le <body>.
// import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title?: string;
  description?: string;
  /** Empêche l'indexation (pages de travail, brouillons). */
  noindex?: boolean;
  /** URL absolue de l'image de partage (défaut : /og.png). */
  ogImage?: string;
  /** Langue de la page : 'fr' (racine) ou 'en' (/en). */
  lang?: 'fr' | 'en';
  /** Chemins relatifs des versions FR/EN pour les balises hreflang. */
  translations?: { fr?: string; en?: string };
}

const siteUrl = 'https://aitom.fr';

const DEFAULTS = {
  fr: {
    title: 'Aitom · Le standard téléphonique IA qui ne rate aucun appel',
    description:
      "Aitom répond à 100 % de vos appels 24h/24, prend vos rendez-vous et qualifie vos clients. Le standard téléphonique IA pour les artisans, cabinets et PME de services.",
    ogLocale: 'fr_FR',
    orgDescription:
      'Standard téléphonique IA pour artisans, cabinets et PME de services : réponse à 100 % des appels, 24h/24, prise de rendez-vous et qualification des clients.',
  },
  en: {
    title: 'Aitom · The AI Answering Service That Never Misses a Call',
    description:
      'Aitom answers 100% of your calls 24/7, books your appointments and qualifies your customers. The AI answering service for tradespeople, practices and service SMBs.',
    ogLocale: 'en_US',
    orgDescription:
      'AI answering service for tradespeople, practices and service SMBs: 100% of calls answered, 24/7, with appointment scheduling and customer qualification.',
  },
};

const { noindex = false, ogImage, lang = 'fr', translations } = Astro.props;
const d = DEFAULTS[lang];
const title = Astro.props.title ?? d.title;
const description = Astro.props.description ?? d.description;

// Canonique propre à chaque page (slash final pour coller aux URLs du sitemap).
const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonical = new URL(pathname, siteUrl).href;

const ogImageUrl = ogImage ?? `${siteUrl}/og.png`;

// Alternances de langue (hreflang) : rendues seulement si fournies.
const alternates = translations
  ? Object.entries(translations)
      .filter(([, href]) => href)
      .map(([hreflang, href]) => ({ hreflang, href: new URL(href!, siteUrl).href }))
  : [];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Aitom',
  url: siteUrl,
  logo: `${siteUrl}/logo-icon.png`,
  description: d.orgDescription,
  email: 'contact@aitom.fr',
  telephone: '+33 7 77 31 32 45',
  sameAs: ['https://www.linkedin.com/company/aitom'],
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    {translations?.fr && <link rel="alternate" hreflang="x-default" href={new URL(translations.fr, siteUrl).href} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Google tag (gtag.js), GA4, Consent Mode v2.
         CHOIX ASSUMÉ (juil. 2026) : analytics_storage accordé par défaut pour une
         mesure complète SANS bannière (sessions, sources, conversions). Ce n'est
         pas conforme RGPD/CNIL en l'état : à la mise en place de la CookieBanner,
         repasser analytics_storage à 'denied' ici, remettre wait_for_update: 500,
         et envoyer gtag('consent', 'update', {...}) à l'acceptation.
         Les signaux publicitaires (ad_*) restent refusés : pas de Google Ads. -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YEXF5GRC6F" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'granted',
      });
      gtag('js', new Date());
      gtag('config', 'G-YEXF5GRC6F');
    </script>

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Aitom" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={d.ogLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Données structurées, Organization -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </head>

  <body class="bg-bg text-ink font-sans antialiased overflow-x-hidden">
    <!-- Film grain overlay -->
    <div class="grain" aria-hidden="true"></div>

    <slot />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Figtree';
    src: url('/fonts/Figtree-Regular.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Figtree';
    src: url('/fonts/Figtree-Italic.woff2') format('woff2');
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: 'Figtree';
    src: url('/fonts/Figtree-Bold.woff2') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Figtree';
    src: url('/fonts/Figtree-BoldItalic.woff2') format('woff2');
    font-weight: 700;
    font-style: italic;
    font-display: swap;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  ::selection {
    background: #6967FB;
    color: #FAF8F2;
  }

  html {
    font-size: 16px;
  }

  /* Grain overlay */
  .grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 500;
    opacity: 0.045;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    mix-blend-mode: multiply;
  }

  /* Scroll-triggered reveal, pilotée par @keyframes (n'entre pas en conflit
     avec les `transition` de survol des cartes, contrairement à un `transition`). */
  [data-animate] {
    opacity: 0;
    will-change: opacity, transform, filter;
  }

  [data-animate].is-visible {
    animation: reveal 950ms cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(32px) scale(0.985);
      filter: blur(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  [data-delay='1'] { animation-delay: 90ms; }
  [data-delay='2'] { animation-delay: 180ms; }
  [data-delay='3'] { animation-delay: 280ms; }
  [data-delay='4'] { animation-delay: 380ms; }
  [data-delay='5'] { animation-delay: 480ms; }

  @media (prefers-reduced-motion: reduce) {
    [data-animate] {
      opacity: 1;
      animation: none;
    }
    [data-animate].is-visible {
      animation: none;
    }
  }

  /* Clamp-based display sizes */
  .text-hero {
    font-size: clamp(2.5rem, 6vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .text-display {
    font-size: clamp(2.25rem, 5vw, 4.5rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .text-display-sm {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  /* Primary button */
  .btn-primary {
    position: relative;
    overflow: hidden;
    transition:
      transform 400ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.14);
    transform: translateX(-101%);
    transition: transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: inherit;
    pointer-events: none;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(105, 103, 251, 0.28);
  }

  .btn-primary:hover::before {
    transform: translateX(0);
  }

  .btn-primary:active {
    transform: translateY(0);
    box-shadow: none;
    transition-duration: 100ms;
  }

  /* Secondary button */
  .btn-secondary {
    position: relative;
  }

  .btn-secondary .btn-label {
    position: relative;
  }

  .btn-secondary .btn-label::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: currentColor;
    transition: width 350ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .btn-secondary:hover .btn-label::after {
    width: 100%;
  }

  /* Smooth scroll offset for fixed nav */
  [id] {
    scroll-margin-top: 80px;
  }

  /* Lenis (inertia smooth scroll), overrides native smooth when active */
  html.lenis,
  html.lenis body {
    height: auto;
  }

  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }

  .lenis.lenis-smooth [data-lenis-prevent] {
    overscroll-behavior: contain;
  }

  .lenis.lenis-stopped {
    overflow: hidden;
  }

  .lenis.lenis-smooth iframe {
    pointer-events: none;
  }
</style>

<script>
  import Lenis from 'lenis';

  // Scroll animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          // Révélation unique : on libère l'élément (et son will-change)
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -80px 0px' }
  );

  document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));

  // Smooth inertia scrolling, skipped when the user prefers reduced motion
  // (native CSS `scroll-smooth` on <html> then handles anchor jumps as a fallback).
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const lenis = new Lenis({
      duration: 1.1,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
      anchors: { offset: -80 }, // clears the 68px fixed nav
    });

    const raf = (time) => {
      lenis.raf(time);
      requestAnimationFrame(raf);
    };
    requestAnimationFrame(raf);
  }
</script>
