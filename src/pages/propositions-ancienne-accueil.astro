---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Cost from '../components/Cost.astro';
import Services from '../components/Services.astro';
import Approach from '../components/Approach.astro';
import Video from '../components/Video.astro';
import TrustLogos from '../components/TrustLogos.astro';
import Work from '../components/Work.astro';
import Platform from '../components/Platform.astro';
import Beyond from '../components/Beyond.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';

// Ancienne page d'accueil (positionnement agence : audit, installation clé
// en main), archivée le 17 juillet 2026 lors du passage au self-serve.
// Conservée en noindex et hors sitemap (préfixe propositions-) pour référence.
const lang = 'fr';
---

<Layout lang={lang} title="Ancienne page d'accueil · Aitom (archive)" noindex>
  <Nav lang={lang} altUrl="/en/" />
  <main>
    <Hero lang={lang} />
    <Cost lang={lang} />
    <Services lang={lang} />
    <Approach lang={lang} />
    <Video lang={lang} />
    <TrustLogos lang={lang} />
    <Work lang={lang} />
    <Platform lang={lang} />
    <Beyond lang={lang} />
    <FAQ lang={lang} />
    <CTASection lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
