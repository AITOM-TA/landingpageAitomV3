---
import Layout from '../layouts/Layout.astro';

// Page de travail : réservation de démo (agenda Cal.com aitom/15min intégré).
// Liée depuis /propositions-saas (bouton « Réserver une démo »).

const APP_URL = 'https://mon.aitom.fr';
---

<Layout title="Réserver une démo · Aitom (page de travail)" noindex>

  <!-- Barre de travail -->
  <div class="work-bar">
    <span class="font-display font-bold text-ink">Aitom · page de travail</span>
    <span class="text-muted text-sm hidden sm:block">Page de réservation de démo liée à la proposition self-serve</span>
  </div>

  <!-- Nav minimale, cohérente avec la proposition -->
  <header class="prop-nav">
    <div class="max-w-container mx-auto px-8 h-full flex items-center justify-between">
      <a href="/propositions-saas" class="flex items-center gap-2.5">
        <img src="/logo-icon.png" alt="" class="h-7 w-7" />
        <span class="font-display font-bold text-ink text-lg">Aitom</span>
      </a>
      <div class="flex items-center gap-4">
        <a href="/propositions-saas" class="hidden sm:block text-sm text-muted hover:text-ink transition-colors duration-200 ease-expo">Retour</a>
        <a href={APP_URL} class="btn-primary inline-block bg-accent text-bg text-sm font-semibold px-5 py-[10px] rounded">
          S'inscrire maintenant
        </a>
      </div>
    </div>
  </header>

  <main class="pt-[112px]">
    <section class="py-10 lg:py-14">
      <div class="max-w-container mx-auto px-8">

        <div class="max-w-[640px] mb-10" data-animate>
          <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-4">Réserver une démo</p>
          <h1 class="font-display font-bold text-display-sm text-ink mb-4">
            15 minutes pour voir Aitom en action.
          </h1>
          <p class="text-muted leading-[1.65]">
            Choisissez le créneau qui vous arrange : on vous montre comment votre
            assistant répondrait à vos appels, et on répond à vos questions.
            Vous préférez écrire ? <a href="mailto:contact@aitom.fr" class="text-accent hover:underline">contact@aitom.fr</a>
          </p>
        </div>

        <!-- Agenda Cal.com (aitom/15min) -->
        <div class="cal-wrap" data-animate data-delay="1">
          <!-- Cal inline embed code begins -->
          <div style="width:100%;height:100%;overflow:scroll" id="my-cal-inline-15min"></div>
          <script type="text/javascript" is:inline>
            (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
            Cal("init", "15min", {origin:"https://app.cal.com"});
            Cal.config = Cal.config || {};
            Cal.config.forwardQueryParams = true;

            Cal.ns["15min"]("inline", {
              elementOrSelector:"#my-cal-inline-15min",
              config: {"layout":"month_view","useSlotsViewOnSmallScreen":"true"},
              calLink: "aitom/15min",
            });

            Cal.ns["15min"]("ui", {"cssVarsPerTheme":{"light":{"cal-brand":"#0c0b1d"},"dark":{"cal-brand":"#4ee2ec"}},"hideEventTypeDetails":false,"layout":"month_view"});
          </script>
          <!-- Cal inline embed code ends -->
        </div>

      </div>
    </section>
  </main>

  <!-- Footer épuré -->
  <footer class="border-t border-border">
    <div class="max-w-container mx-auto px-8 py-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex items-center gap-2.5">
        <img src="/logo-icon.png" alt="" class="h-6 w-6" />
        <span class="font-display font-bold text-ink">Aitom</span>
      </div>
      <p class="text-[13px] text-faint">© 2026 Aitom. Tous droits réservés. Antibes · Côte d'Azur.</p>
    </div>
  </footer>

</Layout>

<style>
  .work-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 1.5rem;
    background: rgba(250, 248, 242, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #dcd5c8;
  }

  .prop-nav {
    position: fixed;
    top: 44px;
    left: 0;
    right: 0;
    z-index: 190;
    height: 68px;
    background: rgba(250, 248, 242, 0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #dcd5c8;
  }

  /* L'iframe Cal.com remplit ce cadre : hauteur généreuse, bordure discrète */
  .cal-wrap {
    height: min(1000px, calc(100vh - 240px));
    min-height: 620px;
    border: 1px solid #dcd5c8;
    border-radius: 8px;
    background: #faf8f2;
    overflow: hidden;
  }
</style>
