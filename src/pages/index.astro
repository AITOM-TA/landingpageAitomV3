<script>
  // Sélecteur Annuel / Mensuel : bascule les prix et les équivalents €/minute.
  const intervalButtons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.interval-btn')
  );
  const priceValues = Array.from(document.querySelectorAll<HTMLElement>('.price-value'));
  const perMinValues = Array.from(document.querySelectorAll<HTMLElement>('.permin'));

  function applyInterval(interval: 'month' | 'year') {
    for (const el of priceValues) el.textContent = el.dataset[interval] ?? '';
    for (const el of perMinValues) el.textContent = el.dataset[interval] ?? '';
    for (const btn of intervalButtons) {
      const active = btn.dataset.interval === interval;
      btn.classList.toggle('is-active', active);
      btn.setAttribute('aria-pressed', String(active));
    }
  }

  for (const btn of intervalButtons) {
    btn.addEventListener('click', () =>
      applyInterval(btn.dataset.interval === 'year' ? 'year' : 'month')
    );
  }
</script>
