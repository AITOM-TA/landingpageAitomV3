---
import Layout from '../layouts/Layout.astro';
import PhoneMock from '../components/PhoneMock.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';

// Page d'accueil (self-serve, depuis le 17 juillet 2026) : héro + logos
// clients, démo à appeler, étapes, cas d'usage, tarifs, FAQ, CTA inscription.
// L'ancienne accueil (positionnement agence) est archivée en noindex sur
// /propositions-ancienne-accueil. Sections et nav inline, propres à cette page.

// Domaine du SaaS self-serve : mon.aitom.fr (app.aitom.fr = ancien SaaS).
const APP_URL = 'https://mon.aitom.fr';
const REGISTER_URL = APP_URL;

// Numéro de démonstration : à remplacer par un vrai numéro Twilio branché
// sur un assistant ElevenLabs dédié (voir la note affichée sur la carte).
const demo = { display: '+33 1 23 45 67 89', tel: '+33123456789' };

// Logos clients (mêmes fichiers que TrustLogos, version compacte pour le header)
const logos = [
  { src: '/logos/kine-brantome.webp', name: 'Cabinet kinés Brantôme' },
  { src: '/logos/pierre-girod.webp', name: 'Cabinet Pierre Girod' },
  { src: '/logos/elecazur.webp', name: 'Elec Azur' },
  { src: '/logos/etude-notariale-antibes.webp', name: 'Étude notariale Antibes' },
  { src: '/logos/expetis.webp', name: 'Expetis' },
  { src: '/logos/renaissens-esthetique.webp', name: 'Renaissens Esthétique' },
  { src: '/logos/rivegauche-gestion.webp', name: 'Rive Gauche Gestion' },
  { src: '/logos/smart-road.webp', name: 'Smart Road' },
];
// Répété 4 fois pour que la piste soit toujours plus large que l'écran :
// l'animation revient à -50 % (2 copies), le motif est identique, la boucle est invisible.
const logoLoop = [...logos, ...logos, ...logos, ...logos];

const stats = [
  { value: '100 %', label: 'des appels décrochés' },
  { value: '< 1 sonnerie', label: 'pour répondre' },
  { value: '24h/24', label: 'nuits, week-ends, fériés' },
  { value: '5 min', label: 'pour être opérationnel' },
];

const steps = [
  {
    number: '01',
    title: 'Créez votre assistant IA',
    description:
      "Choisissez sa voix, sa langue et son message d'accueil, puis décrivez votre activité. Tout se fait depuis l'application, sans aucune compétence technique.",
  },
  {
    number: '02',
    title: 'Définissez son comportement',
    description:
      "Rendez-vous, questions fréquentes, prise de messages, transferts : vous décidez ce qu'il gère et ce qu'il vous transmet, et vous ajustez quand vous voulez.",
  },
  {
    number: '03',
    title: 'Laissez-le répondre au téléphone',
    description:
      "Numéro dédié fourni en un clic, ou simple renvoi d'appel depuis votre numéro actuel. Il décroche dès la première sonnerie, 24h/24.",
  },
];

const useCases = [
  { title: 'Secrétariat', description: "Il accueille, renseigne et prend les messages, comme une secrétaire qui ne part jamais en pause." },
  { title: 'Prise de rendez-vous', description: "Il propose vos créneaux libres et fixe le rendez-vous pendant l'appel, directement dans votre agenda." },
  { title: 'Service client', description: 'Il répond aux questions courantes de vos clients : horaires, tarifs, suivi, informations pratiques.' },
  { title: 'Prise de commande', description: 'Il enregistre les demandes et les commandes, et vous les transmet noir sur blanc, sans erreur de saisie.' },
  { title: 'Urgences et transferts', description: "Il détecte les appels critiques et les transfère immédiatement au bon interlocuteur, avec le contexte." },
  { title: "Et des dizaines d'autres usages", description: 'Qualification des demandes, débordement aux heures de pointe, permanence de nuit : à vous de le configurer.' },
];

// Pricing v2 : miroir exact de saas.plans (l'application fait foi).
// priceMonth/priceYear et perMinMonth/perMinYear alimentent le sélecteur
// Annuel/Mensuel (script en bas de page).
const plans = [
  {
    id: 'starter',
    name: 'Starter',
    tagline: 'Pour 1 à 5 appels / jour',
    pricePrefix: '',
    priceMonth: '29',
    priceYear: '24',
    perMinMonth: '0,12',
    perMinYear: '0,10',
    minutesLabel: '250 minutes',
    included: [
      '3 appels simultanés',
      '1 n° de téléphone (7 €/mois HT par n° supplémentaire)',
      'Assistants illimités',
      '1 utilisateur',
      'Pack 100 minutes : 15 €',
    ],
    featureLeadPlan: null,
    features: ['20+ voix, 25+ langues', 'Base de connaissances', 'Transcriptions et résumés'],
    highlight: false,
    ctaLabel: 'Commencer',
    ctaHref: REGISTER_URL,
  },
  {
    id: 'pro',
    name: 'Pro',
    tagline: 'Pour 5 à 30 appels / jour',
    pricePrefix: '',
    priceMonth: '99',
    priceYear: '84',
    perMinMonth: '0,10',
    perMinYear: '0,08',
    minutesLabel: '1 000 minutes',
    included: [
      '10 appels simultanés',
      '3 n° de téléphone (7 €/mois HT par n° supplémentaire)',
      'Assistants illimités',
      'Pack 100 minutes : 12 €',
    ],
    featureLeadPlan: 'Starter',
    features: ['Transfert vers un humain', 'Prise de rendez-vous (agenda)', 'Support prioritaire'],
    highlight: true,
    ctaLabel: 'Commencer',
    ctaHref: REGISTER_URL,
  },
  {
    id: 'scale',
    name: 'Scale',
    tagline: 'À partir de 30 appels / jour',
    pricePrefix: 'à partir de',
    priceMonth: '499',
    priceYear: '424',
    perMinMonth: '0,10',
    perMinYear: '0,08',
    minutesLabel: '5 000 minutes',
    included: [
      'Appels simultanés sur mesure',
      'Numéros de téléphone sur mesure',
      'Assistants illimités',
      'Pack 100 minutes : 10 €',
    ],
    featureLeadPlan: 'Pro',
    features: ['Appels sortants', 'Accompagnement dédié', 'SLA personnalisé'],
    highlight: false,
    ctaLabel: 'Configurer mon forfait',
    ctaHref: '/propositions-demo',
  },
];

const faqs = [
  {
    question: 'Puis-je garder mon numéro actuel ?',
    answer:
      "Oui. Deux options : vous activez un simple renvoi d'appel de votre numéro actuel vers votre numéro Aitom (rien ne change pour vos clients), ou vous utilisez directement le numéro dédié fourni avec votre abonnement.",
  },
  {
    question: 'Combien de temps pour être opérationnel ?',
    answer:
      "Quelques minutes. Vous créez votre compte, décrivez votre activité, choisissez une voix et connectez votre téléphone. Il n'y a ni rendez-vous d'installation, ni délai : l'assistant répond dès qu'il est activé.",
  },
  {
    question: 'Comment sont décomptées les minutes ?',
    answer:
      "Seule la durée réelle de conversation est décomptée, appel par appel. Vous suivez votre consommation en temps réel dans l'application. Si vous dépassez les minutes incluses, vous ajoutez un pack de 100 minutes en un clic, sans changer de forfait.",
  },
  {
    question: "Que se passe-t-il si l'assistant ne sait pas répondre ?",
    answer:
      "Vous définissez des règles de transfert : sur une question hors périmètre ou à la demande de l'appelant, l'assistant transfère l'appel vers vous ou un collaborateur, et le contexte de la conversation est conservé dans la transcription.",
  },
  {
    question: 'Puis-je résilier à tout moment ?',
    answer:
      "Oui. L'abonnement est mensuel et sans engagement : vous le gérez vous-même depuis la page facturation de l'application, comme n'importe quel outil SaaS.",
  },
  {
    question: 'Qui a accès à mes appels et à mes données ?',
    answer:
      'Uniquement votre organisation. Les transcriptions et enregistrements sont cloisonnés compte par compte, et les données sont traitées dans le respect du RGPD.',
  },
];
---

<Layout translations={{ fr: '/', en: '/en/' }}>

  <SiteNav />

  <main class="pt-[68px]">

    <!-- ============ HERO + bandeau logos dans le header ============ -->
    <section class="relative overflow-hidden" aria-label="Héro">
      <div class="max-w-container mx-auto px-8 w-full pt-14 lg:pt-20 pb-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">

          <div class="max-w-[560px]">
            <p class="text-xs font-sans font-semibold text-accent uppercase tracking-[0.14em] mb-5" data-animate>
              Standard téléphonique IA pour PME
            </p>

            <h1 class="font-display font-bold text-hero text-ink mb-5" data-animate data-delay="1">
              Un appel manqué,<br>c'est un client <em>perdu</em>.
            </h1>

            <p class="text-[17px] leading-[1.65] text-muted max-w-[520px] mb-8" data-animate data-delay="2">
              Créez votre assistant téléphonique IA en quelques minutes : il répond à 100 % de vos appels,
              24h/24, prend vos rendez-vous et renseigne vos clients.
            </p>

            <div class="flex flex-wrap items-center gap-x-10 gap-y-5 mb-7" data-animate data-delay="3">
              <a href={REGISTER_URL} class="btn-primary inline-block bg-accent text-bg text-sm font-semibold px-7 py-[14px] rounded">
                S'inscrire maintenant
              </a>
              <a href="/reserver-une-demo" class="btn-secondary inline-flex items-center gap-2 text-sm text-muted hover:text-ink transition-colors duration-300 ease-expo group">
                <span class="btn-label">Réserver une démo</span>
                <span class="inline-block group-hover:translate-x-2 transition-transform duration-300 ease-expo">→</span>
              </a>
            </div>

            <p class="text-[13px] text-faint" data-animate data-delay="4">
              À partir de 29 €/mois HT · Sans engagement · Prêt en quelques minutes
            </p>
          </div>

          <div class="flex justify-center lg:justify-end" data-animate data-delay="2">
            <PhoneMock />
          </div>

        </div>
      </div>

      <!-- Bandeau des entreprises accompagnées, directement sous le héro -->
      <div class="pb-12" data-animate>
        <p class="hero-trust-label">Plus de 150 entreprises nous font confiance</p>
        <div class="hero-logo-marquee">
          <div class="hero-logo-track">
            {logoLoop.map((logo) => (
              <img src={logo.src} alt={logo.name} class="hero-trust-logo" loading="eager" decoding="async" />
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ DÉMO EN DIRECT (façon fonio : juste après le héro) ============ -->
    <section class="py-section-sm border-t border-border bg-surface" aria-label="Démonstration en direct">
      <div class="max-w-container mx-auto px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">

          <div data-animate>
            <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">Démo en direct</p>
            <h2 class="font-display font-bold text-display-sm text-ink mb-4">
              Écoutez l'assistant<br>avant de créer votre compte.
            </h2>
            <p class="text-muted leading-[1.65] max-w-[480px]">
              Le plus simple pour juger : appelez notre assistant de démonstration.
              Il décroche en une sonnerie, répond à vos questions et peut même vous proposer un rendez-vous,
              exactement comme il le fera pour vos clients.
            </p>
          </div>

          <div class="flex justify-center lg:justify-end" data-animate data-delay="1">
            <div class="demo-card">
              <div class="flex items-center gap-2.5 mb-5">
                <span class="live-dot" aria-hidden="true"></span>
                <span class="text-sm font-semibold text-ink">Assistant de démonstration</span>
              </div>
              <a href={`tel:${demo.tel}`} class="block font-display font-bold text-[28px] sm:text-[34px] text-ink tracking-tight mb-5 hover:text-accent transition-colors duration-200">
                {demo.display}
              </a>
              <a href={`tel:${demo.tel}`} class="btn-primary inline-block bg-accent text-bg text-sm font-semibold px-6 py-3 rounded mb-4">
                Appeler la démo
              </a>
              <p class="text-xs text-faint leading-relaxed">
                Appel non surtaxé, prix d'un appel local.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ============ CHIFFRES CLÉS ============ -->
    <section class="py-14 border-t border-border" aria-label="Chiffres clés">
      <div class="max-w-container mx-auto px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
          {stats.map((stat, i) => (
            <div class="text-center" data-animate data-delay={String(i + 1)}>
              <p class="font-display font-bold text-[32px] md:text-[38px] text-ink leading-none mb-2">{stat.value}</p>
              <p class="text-sm text-muted">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ 3 ÉTAPES (façon fonio : « 60 secondes ») ============ -->
    <section id="fonctionnement" class="py-section-sm md:py-section border-t border-border">
      <div class="max-w-container mx-auto px-8">

        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 pb-8 border-b border-border gap-6">
          <div data-animate>
            <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">Fonctionnement</p>
            <h2 class="font-display font-bold text-display text-ink">Votre assistant, prêt à être<br>testé en 60 secondes.</h2>
          </div>
          <p class="text-muted max-w-[380px] leading-[1.65]" data-animate data-delay="1">
            Aucune compétence technique requise. Tout se fait en ligne, par vous, à votre rythme.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-10 lg:gap-14">
          {steps.map((step, i) => (
            <div data-animate data-delay={String(i + 1)}>
              <p class="font-display font-bold text-[44px] leading-none text-accent-4 mb-5">{step.number}</p>
              <h3 class="font-display font-bold text-xl text-ink mb-3">{step.title}</h3>
              <p class="text-muted leading-[1.65]">{step.description}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ============ CAS D'USAGE (façon fonio : 6 cartes) ============ -->
    <section id="cas-usage" class="py-section-sm md:py-section border-t border-border bg-surface">
      <div class="max-w-container mx-auto px-8">

        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 pb-8 border-b border-border gap-6">
          <div data-animate>
            <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">Cas d'usage</p>
            <h2 class="font-display font-bold text-display text-ink">Un seul assistant,<br>tous vos appels.</h2>
          </div>
          <p class="text-muted max-w-[380px] leading-[1.65]" data-animate data-delay="1">
            Artisans, cabinets médicaux, études, agences : il s'adapte à votre métier, pas l'inverse.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {useCases.map((useCase, i) => (
            <div class="bg-bg border border-border rounded p-7" data-animate data-delay={String((i % 3) + 1)}>
              <h3 class="font-display font-bold text-lg text-ink mb-2.5">{useCase.title}</h3>
              <p class="text-sm text-muted leading-[1.65]">{useCase.description}</p>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ============ TARIFS ============ -->
    <section id="tarifs" class="py-section-sm md:py-section border-t border-border">
      <div class="max-w-container mx-auto px-8">

        <div class="text-center mb-10" data-animate>
          <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">Tarifs</p>
          <h2 class="font-display font-bold text-display text-ink">Simple, transparent,<br>sans engagement.</h2>
        </div>

        <!-- Garantie -->
        <p class="guarantee" data-animate>
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" fill="#6967FB"/>
            <path d="M7.8 12.2l2.6 2.6 5.4-5.8" stroke="#FAF8F2" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Garantie satisfait ou remboursé 30 jours
        </p>

        <!-- Sélecteur Annuel / Mensuel -->
        <div class="interval-toggle" role="group" aria-label="Périodicité de facturation" data-animate>
          <button type="button" class="interval-btn" data-interval="year" aria-pressed="false">
            Annuel <span class="discount">-15%</span>
          </button>
          <button type="button" class="interval-btn is-active" data-interval="month" aria-pressed="true">
            Mensuel
          </button>
        </div>

        <div class="grid md:grid-cols-3 gap-6 items-stretch">
          {plans.map((plan, i) => (
            <div
              class:list={[
                'plan-card relative flex flex-col bg-bg border rounded-[14px] p-8',
                plan.highlight ? 'border-accent shadow-[0_12px_40px_rgba(105,103,251,0.14)]' : 'border-border',
              ]}
              data-animate
              data-delay={String(i + 1)}
            >
              {plan.highlight && <span class="pop-badge">Populaire</span>}

              <h3 class="font-display font-bold text-2xl text-ink mb-1">{plan.name}</h3>
              <p class="text-sm text-muted mb-6">{plan.tagline}</p>

              <p class="mb-7">
                {plan.pricePrefix && (
                  <span class="text-sm font-semibold text-ink">{plan.pricePrefix} </span>
                )}
                <span
                  class="font-display font-bold text-[42px] leading-none text-ink price-value"
                  data-month={plan.priceMonth}
                  data-year={plan.priceYear}
                >{plan.priceMonth}</span>
                <span class="font-display font-bold text-[42px] leading-none text-ink"> €</span>
                <span class="text-muted text-sm"> / mois</span>
              </p>

              <a
                href={plan.ctaHref}
                class:list={[
                  'text-center text-sm font-semibold px-6 py-[13px] rounded-full transition-all duration-200 ease-expo mb-8',
                  plan.highlight ? 'btn-primary bg-accent text-bg' : 'cta-dark',
                ]}
              >
                {plan.ctaLabel}
              </a>

              <div class="border-t border-border pt-6">
                <p class="list-label">Inclus</p>
                <ul class="flex flex-col gap-3 mb-7">
                  <li class="flex items-start gap-2.5 text-sm text-ink">
                    <span class="text-accent mt-[1px]" aria-hidden="true">✓</span>
                    <span>
                      <strong>{plan.minutesLabel}</strong>
                      <span class="text-muted text-[13px]">
                        {' '}correspondent à <span class="permin" data-month={plan.perMinMonth} data-year={plan.perMinYear}>{plan.perMinMonth}</span> €/minute
                      </span>
                    </span>
                  </li>
                  {plan.included.map((item) => (
                    <li class="flex items-start gap-2.5 text-sm text-ink">
                      <span class="text-accent mt-[1px]" aria-hidden="true">✓</span>
                      {item}
                    </li>
                  ))}
                </ul>

                <p class="list-label">Fonctionnalités</p>
                <ul class="flex flex-col gap-3">
                  {plan.featureLeadPlan && (
                    <li class="flex items-start gap-2.5 text-sm text-ink">
                      <span class="text-accent mt-[1px]" aria-hidden="true">←</span>
                      <span>Tout inclus dans <strong>{plan.featureLeadPlan}</strong></span>
                    </li>
                  )}
                  {plan.features.map((feature) => (
                    <li class="flex items-start gap-2.5 text-sm text-ink">
                      <span class="text-accent mt-[1px]" aria-hidden="true">✓</span>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>

        <!-- Entretien avec un expert -->
        <div class="text-center mt-12" data-animate>
          <a href="/reserver-une-demo" class="expert-cta btn-primary">
            Réserver un entretien avec un expert
            <img src="/founder.webp" alt="" class="expert-avatar" loading="lazy" />
          </a>
          <p class="text-[13px] text-faint mt-6">Prix hors TVA</p>
        </div>

      </div>
    </section>

    <!-- ============ FAQ self-serve ============ -->
    <section id="faq" class="py-section-sm md:py-section border-t border-border">
      <div class="max-w-container mx-auto px-8">
        <div class="grid lg:grid-cols-[380px_1fr] gap-12 lg:gap-20">

          <div data-animate>
            <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-3">FAQ</p>
            <h2 class="font-display font-bold text-display-sm text-ink mb-4">Les questions<br>qu'on nous pose.</h2>
            <p class="text-muted leading-[1.65]">
              Une autre question ? Écrivez-nous : <a href="mailto:contact@aitom.fr" class="text-accent hover:underline">contact@aitom.fr</a>
            </p>
          </div>

          <div data-animate data-delay="1">
            {faqs.map((faq) => (
              <details class="pfaq-item border-b border-border">
                <summary class="pfaq-summary">
                  <span class="font-display font-semibold text-ink text-[17px] leading-snug pr-6">{faq.question}</span>
                  <span class="pfaq-icon" aria-hidden="true">+</span>
                </summary>
                <p class="text-muted leading-[1.65] pb-6 max-w-[640px]">{faq.answer}</p>
              </details>
            ))}
          </div>

        </div>
      </div>
    </section>

    <!-- ============ CTA FINAL (façon fonio : « les appels réinventés ») ============ -->
    <section id="contact" class="py-section-sm md:py-section border-t border-border bg-surface">
      <div class="max-w-container mx-auto px-8 text-center">
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.14em] mb-4" data-animate>Lancez-vous</p>
        <h2 class="font-display font-bold text-display text-ink mb-5" data-animate data-delay="1">
          Vos appels, <em>réinventés</em>.
        </h2>
        <p class="text-muted leading-[1.65] max-w-[520px] mx-auto mb-9" data-animate data-delay="2">
          Testez Aitom vous-même : créez votre assistant, connectez votre téléphone,
          et laissez-le prendre le prochain appel que vous ne pouvez pas prendre.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-5" data-animate data-delay="3">
          <a href={REGISTER_URL} class="btn-primary inline-block bg-accent text-bg text-sm font-semibold px-8 py-[15px] rounded">
            S'inscrire maintenant
          </a>
          <a href="/reserver-une-demo" class="btn-secondary inline-flex items-center gap-2 text-sm text-muted hover:text-ink transition-colors duration-300 ease-expo group">
            <span class="btn-label">Vous préférez une démo ? Réserver un créneau</span>
            <span class="inline-block group-hover:translate-x-2 transition-transform duration-300 ease-expo">→</span>
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />

</Layout>

<style>
  /* Ancres : compenser la nav fixe (68px) */
  [id] {
    scroll-margin-top: 90px;
  }

  /* Bandeau logos compact intégré au héro */
  .hero-trust-label {
    text-align: center;
    font-size: 0.72rem;
