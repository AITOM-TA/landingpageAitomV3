---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import BlogArticle from '../../components/BlogArticle.astro';
import { altPair } from '../../i18n/blogAlternates';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.lang === 'fr');
  const sorted = posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
  return sorted.map((post) => ({
    params: { slug: post.id },
    props: { post, related: sorted.filter((p) => p.id !== post.id).slice(0, 2) },
  }));
}

const { post, related } = Astro.props;
const pair = altPair(post.id, 'fr');
const enUrl = pair ? `/en/blog/${pair.en}` : '/en/blog';
const translations = { fr: `/blog/${post.id}/`, en: pair ? `/en/blog/${pair.en}/` : undefined };
const heroAbs = new URL(post.data.heroImage, 'https://aitom.fr').href;
---

<Layout
  lang="fr"
  title={`${post.data.title} · Blog Aitom`}
  description={post.data.description}
  ogImage={heroAbs}
  translations={translations}
>
  <Nav lang="fr" altUrl={enUrl} />
  <BlogArticle post={post} related={related} lang="fr" />
  <Footer lang="fr" />
</Layout>
