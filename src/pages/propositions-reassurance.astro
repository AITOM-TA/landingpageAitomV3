---
import Layout from '../layouts/Layout.astro';

const logos = [
  { src: '/logos/kine-brantome.webp', name: 'Cabinet kinés Brantôme' },
  { src: '/logos/pierre-girod.webp', name: 'Cabinet Pierre Girod' },
  { src: '/logos/elecazur.webp', name: 'Elec Azur' },
  { src: '/logos/etude-notariale-antibes.webp', name: 'Étude notariale Antibes' },
  { src: '/logos/expetis.webp', name: 'Expetis' },
  { src: '/logos/renaissens-esthetique.webp', name: 'Renaissens Esthétique' },
  { src: '/logos/rivegauche-gestion.webp', name: 'Rive Gauche Gestion' },
  { src: '/logos/smart-road.webp', name: 'Smart Road' },
];
// Doublé pour une boucle de marquee sans couture
const loop = [...logos, ...logos];
---

<Layout title="Propositions — réassurance / logos clients (page de travail)" noindex>
  <div class="work-bar">
    <span class="font-display font-bold text-ink">Aitom · page de travail</span>
    <span class="text-muted text-sm">4 propositions de réassurance par les logos — non liée au site</span>
  </div>

  <main class="pt-[44px]">

    <!-- Option 01 — Marquee défilant -->
    <section class="variant">
      <span class="variant-badge">Option 01 · Bandeau qui défile</span>
      <div class="max-w-container mx-auto px-8 w-full">
        <p class="reassurance-label">Ils nous font confiance</p>
      </div>
      <div class="logo-marquee">
        <div class="logo-track">
          {loop.map((l) => <img src={l.src} alt={l.name} class="lm-logo" loading="lazy" />)}
        </div>
      </div>
    </section>

    <!-- Option 02 — Mur de logos (grille) -->
    <section class="variant">
      <span class="variant-badge">Option 02 · Mur de logos (grille)</span>
      <div class="max-w-container mx-auto px-8 w-full">
        <p class="reassurance-label center">Ils nous font confiance</p>
        <div class="logo-grid">
          {logos.map((l) => (
            <div class="logo-cell"><img src={l.src} alt={l.name} class="lg-logo" loading="lazy" /></div>
          ))}
        </div>
      </div>
    </section>

    <!-- Option 03 — Bande sobre centrée -->
    <section class="variant">
      <span class="variant-badge">Option 03 · Bande sobre, sans cadre</span>
      <div class="max-w-container mx-auto px-8 w-full text-center">
        <p class="reassurance-label center">Déjà adoptée par des cabinets et entreprises de la région</p>
        <div class="logo-row">
          {logos.map((l) => <img src={l.src} alt={l.name} class="lr-logo" loading="lazy" />)}
        </div>
      </div>
    </section>

    <!-- Option 04 — Double bandeau (sens opposés) -->
    <section class="variant">
      <span class="variant-badge">Option 04 · Double bandeau croisé</span>
      <div class="max-w-container mx-auto px-8 w-full">
        <p class="reassurance-label">Ils nous font confiance</p>
      </div>
      <div class="logo-marquee">
        <div class="logo-track">
          {loop.map((l) => <img src={l.src} alt={l.name} class="lm-logo" loading="lazy" />)}
        </div>
      </div>
      <div class="logo-marquee mt-8">
        <div class="logo-track reverse">
          {loop.map((l) => <img src={l.src} alt={l.name} class="lm-logo" loading="lazy" />)}
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  .work-bar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    height: 44px; display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; padding: 0 1.5rem;
    background: rgba(250, 248, 242, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #DCD5C8;
    font-size: 0.85rem;
  }

  .variant {
    position: relative;
    padding: 7rem 0;
    border-bottom: 1px solid #DCD5C8;
    overflow: hidden;
  }
  .variant-badge {
    position: absolute; top: 2rem; left: 2rem;
    font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
    color: #6967FB; background: rgba(105, 103, 251, 0.08);
    border: 1px solid rgba(105, 103, 251, 0.25);
    padding: 5px 12px; border-radius: 999px;
  }

  .reassurance-label {
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase;
    color: #B3AA9B; margin-bottom: 2.5rem;
  }
  .reassurance-label.center { text-align: center; }

  /* ── Logo de base ── */
  .lm-logo, .lg-logo, .lr-logo {
    object-fit: contain;
    opacity: 0.55;
    transition: opacity 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Option 01 / 04 — Marquee */
  .logo-marquee { width: 100%; overflow: hidden; -webkit-mask-image: linear-gradient(to right, transparent, #000 8%, #000 92%, transparent); mask-image: linear-gradient(to right, transparent, #000 8%, #000 92%, transparent); }
  .logo-track { display: flex; align-items: center; gap: 4.5rem; width: max-content; animation: logoscroll 38s linear infinite; }
  .logo-track.reverse { animation-direction: reverse; animation-duration: 44s; }
  .logo-track:hover { animation-play-state: paused; }
  .lm-logo { height: 72px; width: auto; flex-shrink: 0; }
  .lm-logo:hover { opacity: 1; }
  @keyframes logoscroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* Option 02 — Grille */
  .logo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: #DCD5C8;
    border: 1px solid #DCD5C8;
    border-radius: 8px;
    overflow: hidden;
  }
  @media (min-width: 640px) { .logo-grid { grid-template-columns: repeat(4, 1fr); } }
  .logo-cell {
    background: #FAF8F2;
    display: flex; align-items: center; justify-content: center;
    min-height: 140px; padding: 1.5rem;
    transition: background-color 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .logo-cell:hover { background: #F1EDE4; }
  .lg-logo { max-height: 92px; max-width: 100%; }
  .logo-cell:hover .lg-logo { opacity: 1; }

  /* Option 03 — Bande sobre */
  .logo-row {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 3rem 4rem;
  }
  .lr-logo { height: 60px; width: auto; }
  .lr-logo:hover { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .logo-track { animation: none; }
  }
</style>
