---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Cost from '../../components/Cost.astro';
import Services from '../../components/Services.astro';
import Approach from '../../components/Approach.astro';
import Video from '../../components/Video.astro';
import TrustLogos from '../../components/TrustLogos.astro';
import Work from '../../components/Work.astro';
import Platform from '../../components/Platform.astro';
import Beyond from '../../components/Beyond.astro';
import FAQ from '../../components/FAQ.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en';
const translations = { fr: '/', en: '/en/' };
---

<Layout lang={lang} translations={translations}>
  <Nav lang={lang} altUrl="/" />
  <main>
    <Hero lang={lang} />
    <Cost lang={lang} />
    <Services lang={lang} />
    <Approach lang={lang} />
    <Video lang={lang} />
    <TrustLogos lang={lang} />
    <Work lang={lang} />
    <Platform lang={lang} />
    <Beyond lang={lang} />
    <FAQ lang={lang} />
    <CTASection lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
